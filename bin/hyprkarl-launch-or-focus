#!/bin/bash
# hyprkarl-launch-or-focus
# Focuses an existing window matching the given pattern, or launches a new
# instance if none is found. Matches against both window class and title.
#
# Usage:
#   hyprkarl-launch-or-focus <window-pattern> [launch-command]
#
#   window-pattern   Case-insensitive pattern matched against window class and title.
#   launch-command   Command to run if no matching window is found.
#                    Defaults to "uwsm-app -- <window-pattern>" if omitted.
#
# Examples:
#   hyprkarl-launch-or-focus firefox
#   hyprkarl-launch-or-focus nmtui "hyprkarl-launch-tui nmtui"

if (($# == 0)); then
  echo "Usage: hyprkarl-launch-or-focus [window-pattern] [launch-command]"
  exit 1
fi

WINDOW_PATTERN="$1"
LAUNCH_COMMAND="${2:-"uwsm-app -- $WINDOW_PATTERN"}"
WINDOW_ADDRESS=$(hyprctl clients -j | jq -r --arg p "$WINDOW_PATTERN" '.[]|select((.class|test("\\b" + $p + "\\b";"i")) or (.title|test("\\b" + $p + "\\b";"i")))|.address' | head -n1)

if [[ -n $WINDOW_ADDRESS ]]; then
  hyprctl dispatch focuswindow "address:$WINDOW_ADDRESS"
else
  eval exec setsid $LAUNCH_COMMAND
fi
