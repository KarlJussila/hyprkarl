#!/bin/bash
# hyprkarl-find-icon
# Finds an icon file by name, searching the hyprkarl theme icons first,
# then the current GTK icon theme with fallback to Yaru and hicolor.
#
# Usage:
#   hyprkarl-find-icon <icon-name> [category...]
#
# Categories are only used when searching system icon themes, and default
# to "actions" if omitted. Multiple categories are searched in order.

# Examples:
#   hyprkarl-find-icon media-playback-start-symbolic
#   hyprkarl-find-icon audio-volume-high-symbolic status actions

icon_name="${1:-}"
[[ -n "$icon_name" ]] || { echo "Usage: hyprkarl-find-icon <icon-name> [category...]" >&2; exit 1; }
shift

categories=("${@:-actions}")

hyprkarl_icons="$HOME/.config/hyprkarl/current/theme/icons"
icon_theme=$(gsettings get org.gnome.desktop.interface icon-theme | tr -d "'")

# Check hyprkarl theme icons first — flat directory, no categories
path="$hyprkarl_icons/${icon_name}.svg"
if [[ -f "$path" ]]; then
    echo "$path"
    exit 0
fi

# Fall back to system icon themes with category search
for theme_dir in "/usr/share/icons/$icon_theme" "/usr/share/icons/Yaru" "/usr/share/icons/hicolor"; do
    for category in "${categories[@]}"; do
        path="$theme_dir/scalable/$category/${icon_name}.svg"
        if [[ -f "$path" ]]; then
            echo "$path"
            exit 0
        fi
    done
done

exit 1