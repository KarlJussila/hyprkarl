#!/bin/bash
# hk-menu-power
# Power Menu
#
# Usage:
#   hk-menu-power [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

ROFI_THEME="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/custom-menu.rasi"

BACK=()
if [[ "${1:-}" == "--back" ]]; then
  shift; BACK=("$@")
fi

LOCK=" Lock"
SUSPEND=" Suspend"
REBOOT=" Reboot"
SHUTDOWN=" Shutdown"

CHOICE=$(echo -e "$LOCK\n$SUSPEND\n$REBOOT\n$SHUTDOWN" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Power Menu" \
           -theme "$ROFI_THEME")

case "$CHOICE" in
    "$LOCK")     hk-lock ;;
    "$SUSPEND")  hk-suspend ;;
    "$REBOOT")   hk-reboot ;;
    "$SHUTDOWN") hk-shutdown ;;
    "")          (( ${#BACK[@]} )) && "${BACK[@]}" ;;
esac
