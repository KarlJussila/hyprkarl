#!/bin/bash

# Menu for selecting a default terminal emulator

# Usage:
#   hyprkarl-menu-terminal [back_cmd]

#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

back_cmd="${1:-}"

ALACRITTY="Alacritty"
GHOSTTY="Ghostty"
KITTY="Kitty"
FOOT="Foot"

CHOICE=$(echo -e "$ALACRITTY\n$GHOSTTY\n$KITTY\n$FOOT" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Default Terminal" \
           -theme ~/.config/rofi/custom-menu.rasi) \
           || pkill rofi

case "$CHOICE" in
    "$ALACRITTY") hyprkarl-default-terminal alacritty ;;
    "$GHOSTTY")   hyprkarl-default-terminal ghostty ;;
    "$KITTY")     hyprkarl-default-terminal kitty ;;
    "$FOOT")      hyprkarl-default-terminal foot ;;
    "")           [[ -n "$back_cmd" ]] && $back_cmd ;;
esac