#!/bin/bash
# hk-menu-utils
# Menu for common utilities

ROFI_THEME="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/custom-menu.rasi"

CAFFEINE="¯░ò Caffeine"
NIGHTLIGHT="´â½ Nightlight"
SCREEN_RECORD="´Ç¢ Screen Record"
AGS="´æÁ AGS Bar"

case "$(powerprofilesctl get)" in
    "power-saver")    POWER_PROFILE_ICON="¾░î¬" ;;
    "balanced")       POWER_PROFILE_ICON="¾░ùæ" ;;
    "performance")    POWER_PROFILE_ICON="¾▒Éï" ;;
    *)                POWER_PROFILE_ICON="¾░ùæ" ;;
esac
POWER_PROFILE="$POWER_PROFILE_ICON Power Profile"

relaunch_menu() { exec "$0"; }

CHOICE=$(echo -e "$CAFFEINE\n$NIGHTLIGHT\n$SCREEN_RECORD\n$POWER_PROFILE\n$AGS" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Utilities" \
           -theme "$ROFI_THEME")

case "$CHOICE" in
    "$CAFFEINE")      hk-caffeine ;;
    "$NIGHTLIGHT")    hk-nightlight ;;
    "$SCREEN_RECORD") sleep 0.5 && hk-record-screen ;;
    "$POWER_PROFILE") hk-menu-power-profile || relaunch_menu ;;
    "$AGS")           hk-menu-ags || relaunch_menu ;;
    "")               exit 1 ;;
esac

exit 0
