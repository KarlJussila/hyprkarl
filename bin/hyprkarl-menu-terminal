#!/bin/bash
# hyprkarl-menu-terminal
# Menu for selecting a default terminal emulator
#
# Usage:
#   hyprkarl-menu-terminal [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-shell.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-shell.sh"

hyprkarl_parse_back_args "$@"

ALACRITTY="Ａ Alacritty"
GHOSTTY=" Ghostty"
KITTY="󰄛 Kitty"
FOOT="󰽒 Foot"

CHOICE=$(echo -e "$ALACRITTY\n$GHOSTTY\n$KITTY\n$FOOT" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Default Terminal" \
           -theme "$HYPRKARL_ROFI_CUSTOM_THEME")

case "$CHOICE" in
    "$ALACRITTY") hyprkarl-default-terminal alacritty ;;
    "$GHOSTTY")   hyprkarl-default-terminal ghostty ;;
    "$KITTY")     hyprkarl-default-terminal kitty ;;
    "$FOOT")      hyprkarl-default-terminal foot ;;
    "")           hyprkarl_run_back "${HYPRKARL_BACK_ARGS[@]}" ;;
esac
