#!/bin/bash
# hk-menu-docker-uninstall
# Menu for uninstalling Docker service stacks.
#
# Usage:
#   hk-menu-docker-uninstall [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
source "$SCRIPT_DIR/lib/docker.sh"
ROFI_THEME="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/custom-menu.rasi"

hyprkarl_parse_back_args "$@"

CHOICES=()
CHOICE_IDS=()

while IFS=$'\t' read -r service_id service_label; do
    [[ -n "$service_id" ]] || continue
    CHOICES+=("$service_label")
    CHOICE_IDS+=("$service_id")
done < <(docker_list_services installed)

if (( ${#CHOICE_IDS[@]} == 0 )); then
    CHOICES=("(nothing to remove)")
    MESG="No containers installed"
else
    MESG="Uninstall Service"
fi

CHOICE=$(printf '%s\n' "${CHOICES[@]}" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "$MESG" \
           -theme "$ROFI_THEME")

case "$CHOICE" in
    "")         hyprkarl_run_back "${HYPRKARL_BACK_ARGS[@]}" ;;
esac

for index in "${!CHOICE_IDS[@]}"; do
    if [[ "$CHOICE" == "${CHOICES[$index]}" ]]; then
        hyprkarl_open_terminal hk-docker uninstall "${CHOICE_IDS[$index]}"
        exit 0
    fi
done
