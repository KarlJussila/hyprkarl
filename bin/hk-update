#!/bin/bash
# hk-update
# Apply updates to hyprkarl after merging upstream changes.
#
# Usage:
#   hk-update check
#   hk-update dotfiles [--force|--adopt]
#   hk-update remove-stale
#   hk-update packages
#   hk-update system
#   hk-update all [--force|--adopt]

usage() {
  cat <<'EOF'
Usage:
  hk-update check                Report what would change (no side effects)
  hk-update dotfiles             Restow config files and remove stale symlinks
  hk-update dotfiles --force     Overwrite conflicting ~/.config files with repo versions
  hk-update dotfiles --adopt     Adopt conflicting ~/.config files into the repo for review
  hk-update remove-stale         Remove stale hyprkarl symlinks and empty directories
  hk-update packages             Install new required packages, prompt for dropped ones
  hk-update system               Re-run system-level setup
  hk-update all [--force|--adopt]  Run dotfiles, packages, and system in sequence
  hk-update tui                  Interactive guided update (sync, review, apply)
EOF
}

action=${1:-}
shift || true

case "$action" in
  all)
    dotfiles_flags=()
    for arg in "$@"; do
      case "$arg" in
        --force|--adopt) dotfiles_flags+=("$arg") ;;
        *) printf 'Unknown option: %s\n' "$arg" >&2; usage >&2; exit 1 ;;
      esac
    done
    hk-update-dotfiles "${dotfiles_flags[@]}" || exit 1
    hk-update-packages || exit 1
    hk-update-system   || exit 1
    ;;
  check|dotfiles|packages|system|remove-stale|tui)
    exec "hk-update-$action" "$@" ;;
  ""|-h|--help|help)
    usage; exit 0 ;;
  *)
    usage >&2; exit 1 ;;
esac
