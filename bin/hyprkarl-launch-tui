#!/bin/bash
# hyprkarl-launch-tui
# Launches a TUI command in the default terminal with a hyprkarl app ID,
# allowing it to be styled independently via window rules.
#
# Usage:
#   hyprkarl-launch-tui <command> [args...]
#
# Example:
#   hyprkarl-launch-tui btop
#   hyprkarl-launch-tui nvim ~/notes.md

exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.hyprkarl.$(basename $1) -e "$1" "${@:2}"
