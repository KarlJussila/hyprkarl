#!/bin/bash
# hyprkarl-menu-docker-install
# Menu for installing Docker and Docker containers.
# Shows only the Docker install option until Docker is set up, then
# exposes container install options.
#
# Usage:
#   hyprkarl-menu-docker-install [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-docker.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-docker.sh"

hyprkarl_parse_back_args "$@"
hyprkarl_build_self_command "$0"

DOCKER="󰡨 Install Docker"
CHOICES=()
CHOICE_IDS=()

if ! hyprkarl_docker_ready; then
    CHOICES=("$DOCKER")
    MESG="Docker Setup"
else
    MESG="Install Container"
    while IFS= read -r service_id; do
        hyprkarl_docker_load_service "$service_id" || exit 1
        if [[ ! -f "$(hyprkarl_docker_compose_path)" ]]; then
            CHOICES+=("$HYPRKARL_DOCKER_SERVICE_LABEL")
            CHOICE_IDS+=("$service_id")
        fi
    done < <(hyprkarl_docker_service_ids)

    if (( ${#CHOICE_IDS[@]} == 0 )); then
        CHOICES=("(nothing to install)")
    fi
fi

CHOICE=$(printf '%s\n' "${CHOICES[@]}" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "$MESG" \
           -theme "$HYPRKARL_ROFI_CUSTOM_THEME")

case "$CHOICE" in
    "$DOCKER")  hyprkarl_open_terminal hyprkarl-docker-install ;;
    "")         hyprkarl_run_back "${HYPRKARL_BACK_ARGS[@]}" ;;
esac

for index in "${!CHOICE_IDS[@]}"; do
    if [[ "$CHOICE" == "${CHOICES[$index]}" ]]; then
        hyprkarl_open_terminal "hyprkarl-docker-${CHOICE_IDS[$index]}"
        exit 0
    fi
done
