#!/bin/bash

# hyprkarl-fingerprint-remove
# Removes an enrolled fingerprint.

# Usage:
#   hyprkarl-fingerprint-remove <finger-name>
#
# Example:
#   hyprkarl-fingerprint-remove left-index-finger

finger="$1"

if [[ -z "$finger" ]]; then
  echo "Usage: hyprkarl-fingerprint-remove <finger-name>" >&2
  exit 1
fi

if ! fprintd-delete "$USER" -f "$finger" 2>/dev/null; then
  echo "Failed to remove fingerprint: $finger" >&2
  exit 1
fi