#!/bin/bash
# hyprkarl-brightness-display
# Adjust brightness on the most likely display device and show OSD
#
# Usage:
#   hyprkarl-brightness-display <step>

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-shell.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-shell.sh"

ICON_BRIGHTNESS=$(hyprkarl-find-icon "display-brightness-symbolic" status actions)

step="${1:-+5%}"

device=$(hyprkarl_find_display_backlight) || {
    echo "No display backlight device found." >&2
    exit 1
}

brightnessctl -d "$device" set "$step" >/dev/null

brightness="$(brightnessctl -d "$device" -m | cut -d',' -f4 | tr -d '%')"

notify-send \
    -h string:x-canonical-private-synchronous:brightness \
    -h int:value:"$brightness" \
    -a "osd-brightness" \
    "Brightness" "${brightness}%" \
    --icon="$ICON_BRIGHTNESS"
