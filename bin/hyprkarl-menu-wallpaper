#!/bin/bash
# hyprkarl-menu-wallpaper
# Submenu for wallpaper management
#
# Usage:
#   hyprkarl-menu-wallpaper [back_cmd]
#
#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

terminal() {
    local tmp=$(mktemp)
    xdg-terminal-exec --app-id=org.hyprkarl.terminal -e bash -c "$1 > $tmp"
    cat "$tmp"
    rm "$tmp"
}

back_cmd="$*"

SELECT="󰋹 Select"
ADD=" Add"
REMOVE=" Remove"

CHOICE=$(echo -e "$SELECT\n$ADD\n$REMOVE" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Wallpaper" \
           -theme ~/.config/rofi/custom-menu.rasi)

case "$CHOICE" in
    "$SELECT") hyprkarl-wallpaper-set "$(hyprkarl-wallpaper-select)" ;;
    "$ADD")    hyprkarl-wallpaper-add "$(terminal hyprkarl-select-picture)" ;;
    "$REMOVE") hyprkarl-wallpaper-remove "$(hyprkarl-wallpaper-select '@urgent')" ;;
    "")        [[ -n "$back_cmd" ]] && $back_cmd ;;
esac