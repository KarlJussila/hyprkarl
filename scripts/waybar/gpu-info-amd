#!/usr/bin/env bash
# gpu-info-amd
# AMD-specific GPU info for Waybar.
#
# Usage:
#   gpu-info-amd <card> <name>

card="$1"
name="$2"

usage_amd() {
    local f="/sys/class/drm/${card}/device/gpu_busy_percent"
    [[ ! -r "$f" ]] && { echo "N/A"; return; }
    local pct
    pct=$(cat "$f" 2>/dev/null) || pct="0"
    echo "${pct}%"
}

vram_amd() {
    local used_file="/sys/class/drm/${card}/device/mem_info_vram_used"
    local total_file="/sys/class/drm/${card}/device/mem_info_vram_total"
    [[ -r "$used_file" && -r "$total_file" ]] || { echo "N/A"; return; }
    local used total
    used=$(< "$used_file")
    total=$(< "$total_file")
    awk "BEGIN{printf \"%.1f/%.1f GiB\n\", $used/1073741824, $total/1073741824}"
}

usage=$(usage_amd)
vram=$(vram_amd)

# If both usage and vram are inaccessible, signal failure so the caller
# can fall back to the next best card
if [[ "$usage" == "N/A" && "$vram" == "N/A" ]]; then
    echo '{"text":"N/A","alt":"N/A","tooltip":"'"${name}"'"}'
    exit 1
fi

echo "{\"text\":\"${usage}\",\"alt\":\"${usage} | ${vram}\",\"tooltip\":\"${name}\"}"
