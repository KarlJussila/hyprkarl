#!/bin/bash

# hyprkarl-find-icon
# Finds an icon file by name, searching the current GTK icon theme with
# fallback to Yaru and hicolor.

# Usage:
#   hyprkarl-find-icon <icon-name> [category...]

# Categories default to "actions" if omitted. Multiple categories are
# searched in the order provided.

# Examples:
#   hyprkarl-find-icon media-playback-start-symbolic
#   hyprkarl-find-icon audio-volume-high-symbolic status actions

icon_name="${1:-}"
[[ -n "$icon_name" ]] || { echo "Usage: hyprkarl-find-icon <icon-name> [category...]" >&2; exit 1; }
shift

categories=("${@:-actions}")

icon_theme=$(gsettings get org.gnome.desktop.interface icon-theme | tr -d "'")

for theme in "$icon_theme" "Yaru" "hicolor"; do
    for category in "${categories[@]}"; do
        path="/usr/share/icons/$theme/scalable/$category/${icon_name}.svg"
        if [[ -f "$path" ]]; then
            echo "$path"
            exit 0
        fi
    done
done

exit 1