#!/bin/bash
# hyprkarl-menu
# Main hyprkarl menu
#
# Usage:
#   hyprkarl-menu [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-shell.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-shell.sh"

hyprkarl_parse_back_args "$@"
hyprkarl_build_self_command "$0"

LAUNCH="󱓟 Launch"
INSTALL=" Install"
UNINSTALL="󱧖 Uninstall"
UTILS=" Utilities"
CONFIG=" Config"
POWER=" Power"

CHOICE=$(echo -e "$LAUNCH\n$INSTALL\n$UNINSTALL\n$UTILS\n$CONFIG\n$POWER" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Main Menu" \
           -theme "$HYPRKARL_ROFI_CUSTOM_THEME")

case "$CHOICE" in
    "$LAUNCH")    hyprkarl-menu-launcher ;;
    "$INSTALL")   hyprkarl-menu-install --back "${HYPRKARL_SELF_COMMAND[@]}" ;;
    "$UNINSTALL") hyprkarl-menu-uninstall --back "${HYPRKARL_SELF_COMMAND[@]}" ;;
    "$UTILS")     hyprkarl-menu-utils --back "${HYPRKARL_SELF_COMMAND[@]}" ;;
    "$CONFIG")    hyprkarl-menu-config --back "${HYPRKARL_SELF_COMMAND[@]}" ;;
    "$POWER")     hyprkarl-menu-power --back "${HYPRKARL_SELF_COMMAND[@]}" ;;
    "")           hyprkarl_run_back "${HYPRKARL_BACK_ARGS[@]}" ;;
esac
