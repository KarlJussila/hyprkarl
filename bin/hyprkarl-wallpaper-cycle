#!/bin/bash

# Cycles through wallpapers for the current theme

WALLPAPERS_PATH="$HYPRKARL_PATH/config/hyprkarl/current/theme/wallpapers/"
CURRENT_WALLPAPER_LINK="$HYPRKARL_PATH/config/hyprkarl/current/wallpaper"

mapfile -d '' -t WALLPAPERS < <(find -L "$WALLPAPERS_PATH" -maxdepth 1 -type f -print0 2>/dev/null | sort -z)
TOTAL=${#WALLPAPERS[@]}

if [[ $TOTAL -eq 0 ]]; then
  notify-send "No wallpaper was found for current theme" -t 2000
else
  # Get current wallpaper from symlink
  if [[ -L "$CURRENT_WALLPAPER_LINK" ]]; then
    CURRENT_WALLPAPER=$(readlink "$CURRENT_WALLPAPER_LINK")
    CURRENT_WALLPAPER="$WALLPAPERS_PATH$(basename "$CURRENT_WALLPAPER")"
  else
    CURRENT_WALLPAPER=""
  fi

  # Find current wallpaper index
  INDEX=-1
  for i in "${!WALLPAPERS[@]}"; do
    if [[ "${WALLPAPERS[$i]}" == "$CURRENT_WALLPAPER" ]]; then
      INDEX=$i
      break
    fi
  done

  # Get next wallpaper (wrap around)
  if [[ $INDEX -eq -1 ]]; then
    NEW_WALLPAPER="${WALLPAPERS[0]}"
  else
    NEXT_INDEX=$(((INDEX + 1) % TOTAL))
    NEW_WALLPAPER="${WALLPAPERS[$NEXT_INDEX]}"
  fi

  # Update symlink
  ln -nsf "theme/wallpapers/$(basename "$NEW_WALLPAPER")" "$CURRENT_WALLPAPER_LINK"

  # Switch wallpaper via hyprpaper socket
  hyprctl hyprpaper wallpaper ",$NEW_WALLPAPER"
fi