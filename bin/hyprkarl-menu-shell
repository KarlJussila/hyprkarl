#!/bin/bash
# hyprkarl-menu-shell
# Menu for selecting a default shell
#
# Usage:
#   hyprkarl-menu-shell [back_cmd]
#
#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

terminal() {
  xdg-terminal-exec --app-id=org.hyprkarl.terminal "$@"
}

back_cmd="$*"

FISH=" Fish"
ZSH="󰰶 Zsh"
BASH="󱆃 Bash"

CHOICE=$(echo -e "$FISH\n$ZSH\n$BASH" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Default Shell" \
           -theme ~/.config/rofi/custom-menu.rasi)

case "$CHOICE" in
    "$FISH") terminal hyprkarl-default-shell fish ;;
    "$ZSH")  terminal hyprkarl-default-shell zsh ;;
    "$BASH") terminal hyprkarl-default-shell bash ;;
    "")      [[ -n "$back_cmd" ]] && $back_cmd ;;
esac