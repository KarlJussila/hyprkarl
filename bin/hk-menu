#!/bin/bash
# hk-menu
# Main hyprkarl menu
#
# Usage:
#   hk-menu [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
source "$SCRIPT_DIR/lib/shell.sh"
ROFI_THEME="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/custom-menu.rasi"

BACK=()
if [[ "${1:-}" == "--back" ]]; then
  shift; BACK=("$@")
fi
SELF=("$(basename "$0")")
[[ -n "${BACK[*]}" ]] && SELF+=(--back "${BACK[@]}")  # carry back-chain so submenus can return here

LAUNCH="¾▒ō¤ Launch"
INSTALL="’Éē Install"
UNINSTALL="¾▒¦¢ Uninstall"
UTILS="ŅŁŁ Utilities"
CONFIG="’Ćō Config"
POWER="’Ćæ Power"

CHOICE=$(echo -e "$LAUNCH\n$INSTALL\n$UNINSTALL\n$UTILS\n$CONFIG\n$POWER" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Main Menu" \
           -theme "$ROFI_THEME")

case "$CHOICE" in
    "$LAUNCH")    hk-menu-launcher ;;
    "$INSTALL")   hk-menu-install --back "${SELF[@]}" ;;
    "$UNINSTALL") hk-menu-uninstall --back "${SELF[@]}" ;;
    "$UTILS")     hk-menu-utils --back "${SELF[@]}" ;;
    "$CONFIG")    hk-menu-config --back "${SELF[@]}" ;;
    "$POWER")     hk-menu-power --back "${SELF[@]}" ;;
    "")           [[ -n "${BACK[*]}" ]] && "${BACK[@]}" ;;
esac
