#!/bin/bash
# hyprkarl-menu-shell
# Menu for selecting a default shell
#
# Usage:
#   hyprkarl-menu-shell [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-shell.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-shell.sh"

hyprkarl_parse_back_args "$@"

FISH=" Fish"
ZSH="󰰶 Zsh"
BASH="󱆃 Bash"

CHOICE=$(echo -e "$FISH\n$ZSH\n$BASH" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Default Shell" \
           -theme "$HYPRKARL_ROFI_CUSTOM_THEME")

case "$CHOICE" in
    "$FISH") hyprkarl_open_terminal hyprkarl-default-shell fish ;;
    "$ZSH")  hyprkarl_open_terminal hyprkarl-default-shell zsh ;;
    "$BASH") hyprkarl_open_terminal hyprkarl-default-shell bash ;;
    "")      hyprkarl_run_back "${HYPRKARL_BACK_ARGS[@]}" ;;
esac
