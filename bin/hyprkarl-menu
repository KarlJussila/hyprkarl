#!/bin/bash
# hyprkarl-menu
# Main hyprkarl menu
#
# Usage:
#   hyprkarl-menu [back_cmd]
#
#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

back_cmd="$*"

LAUNCH="¾▒ō¤ Launch"
INSTALL="’Éē Install"
UNINSTALL="¾▒¦¢ Uninstall"
UTILS="ŅŁŁ Utilities"
CONFIG="’Ćō Config"
POWER="’Ćæ Power"

CHOICE=$(echo -e "$LAUNCH\n$INSTALL\n$UNINSTALL\n$UTILS\n$CONFIG\n$POWER" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Main Menu" \
           -theme ~/.config/rofi/custom-menu.rasi)

case "$CHOICE" in
    "$LAUNCH")    hyprkarl-menu-launcher "hyprkarl-menu${back_cmd:+ $back_cmd}" ;;
    "$INSTALL")   hyprkarl-menu-install "hyprkarl-menu${back_cmd:+ $back_cmd}" ;;
    "$UNINSTALL") hyprkarl-menu-uninstall "hyprkarl-menu${back_cmd:+ $back_cmd}" ;;
    "$UTILS")     hyprkarl-menu-utils "hyprkarl-menu${back_cmd:+ $back_cmd}" ;;
    "$CONFIG")    hyprkarl-menu-config "hyprkarl-menu${back_cmd:+ $back_cmd}" ;;
    "$POWER")     hyprkarl-menu-power "hyprkarl-menu${back_cmd:+ $back_cmd}" ;;
    "")           [[ -n "$back_cmd" ]] && $back_cmd ;;
esac