#!/bin/bash
# hyprkarl-battery-monitor
# Monitors battery level and fires actions at configured thresholds

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-shell.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-shell.sh"

POLL_INTERVAL=30
FIRED_FILE="$HYPRKARL_RUNTIME_DIR/battery-fired"

mkdir -p "$HYPRKARL_RUNTIME_DIR"

BATTERY=$(hyprkarl_find_battery) || {
    echo "No battery device found; battery monitor disabled." >&2
    exit 0
}

at_battery() {
    local threshold="$1"

    [[ "$status" == "Charging" || "$status" == "Full" ]] && return 1
    grep -qx "$threshold" "$FIRED_FILE" 2>/dev/null && return 1
    [[ "$level" -le "$threshold" ]] || return 1

    echo "$threshold" >> "$FIRED_FILE"
    return 0
}

reset_if_charging() {
    status=$(< "/sys/class/power_supply/$BATTERY/status")
    if [[ "$status" == "Charging" || "$status" == "Full" ]]; then
        rm -f "$FIRED_FILE"
    fi
}

while true; do
    level=$(< "/sys/class/power_supply/$BATTERY/capacity")
    status=$(< "/sys/class/power_supply/$BATTERY/status")

    echo "$status: $level%"

    reset_if_charging

    # Notify at 20%
    if at_battery 20; then
        hyprkarl-notify-battery "Battery Low: %p%"
    fi

    # And 10%
    if at_battery 10; then
        hyprkarl-notify-battery "Battery Low: %p%"
    fi

    # And at 5% (critical)
    if at_battery 5; then
        hyprkarl-notify-battery -c "Battery Low: %p%"
    fi

    sleep "$POLL_INTERVAL"
done
