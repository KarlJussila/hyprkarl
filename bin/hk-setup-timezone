#!/bin/bash
# hk-setup-timezone
# Show a gum TUI for setting the system timezone

timezone=$(timedatectl list-timezones | gum filter --height 20 --header "Set timezone") || exit 1
sudo timedatectl set-timezone "$timezone"
echo "Timezone is now set to $timezone. Restarting waybar."
hk-waybar-restart
hk-show-done
