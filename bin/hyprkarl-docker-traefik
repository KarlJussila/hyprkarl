#!/bin/bash
# hyprkarl-docker-traefik
# Installs or removes Traefik as a reverse proxy for local Docker services.
#
# Usage:
#   hyprkarl-docker-traefik [--remove]

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-docker.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-docker.sh"

hyprkarl_docker_run_service_command traefik "$@"
