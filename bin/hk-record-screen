#!/bin/bash
# Start and stop a screenrecording, which will be saved to ~/Videos by default.
# Alternative location can be set via HYPRKARL_SCREENRECORD_DIR or XDG_VIDEOS_DIR ENVs.
# Resolution is capped to 4K for monitors above 4K, native otherwise.
# Override via --resolution= (e.g. --resolution=1920x1080, --resolution=0x0 for native).

default_videos_dir=$(xdg-user-dir VIDEOS 2>/dev/null)
[[ -n "$default_videos_dir" ]] || default_videos_dir="$HOME/Videos"

OUTPUT_DIR="${HYPRKARL_SCREENRECORD_DIR:-${XDG_VIDEOS_DIR:-$default_videos_dir}}"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}/hyprkarl"
PID_FILE="$RUNTIME_DIR/screenrecording.pid"
RECORDING_FILE="$RUNTIME_DIR/screenrecording.path"
WEBCAM_PID_FILE="$RUNTIME_DIR/screenrecording-webcam.pid"

if [[ ! -d $OUTPUT_DIR ]]; then
  notify-send "Screen recording directory does not exist: $OUTPUT_DIR" -u critical -t 3000
  exit 1
fi

mkdir -p "$RUNTIME_DIR"

DESKTOP_AUDIO="false"
MICROPHONE_AUDIO="false"
WEBCAM="false"
WEBCAM_DEVICE=""
RESOLUTION=""
STOP_RECORDING="false"

for arg in "$@"; do
  case "$arg" in
  --with-desktop-audio) DESKTOP_AUDIO="true" ;;
  --with-microphone-audio) MICROPHONE_AUDIO="true" ;;
  --with-webcam) WEBCAM="true" ;;
  --webcam-device=*) WEBCAM_DEVICE="${arg#*=}" ;;
  --resolution=*) RESOLUTION="${arg#*=}" ;;
  --stop-recording) STOP_RECORDING="true" ;;
  esac
done

read_pid_file() {
  local pid_file="$1"
  local pid=""

  [[ -f "$pid_file" ]] || return 1

  pid=$(< "$pid_file")
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1

  printf '%s\n' "$pid"
}

recording_pid() {
  local pid
  pid=$(read_pid_file "$PID_FILE") || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  printf '%s\n' "$pid"
}

screenrecording_active() {
  recording_pid >/dev/null || {
    rm -f "$PID_FILE"
    return 1
  }

  return 0
}

find_webcam_device() {
  v4l2-ctl --list-devices 2>/dev/null \
    | awk '/^[[:space:]]*\/dev\/video/ { gsub(/\t/, "", $0); print; exit }'
}

start_webcam_overlay() {
  cleanup_webcam

  # Auto-detect first available webcam if none specified
  if [[ -z $WEBCAM_DEVICE ]]; then
    WEBCAM_DEVICE=$(find_webcam_device)
    if [[ -z $WEBCAM_DEVICE ]]; then
      notify-send "No webcam devices found" -u critical -t 3000
      return 1
    fi
  fi

  # Get monitor scale
  local scale=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true) | .scale')

  # Target width (base 360px, scaled to monitor)
  local target_width=$(awk "BEGIN {printf \"%.0f\", 360 * $scale}")

  # Try preferred 16:9 resolutions in order, use first available
  local preferred_resolutions=("640x360" "1280x720" "1920x1080")
  local ffplay_args=(-f v4l2)
  local available_formats=$(v4l2-ctl --list-formats-ext -d "$WEBCAM_DEVICE" 2>/dev/null)

  for resolution in "${preferred_resolutions[@]}"; do
    if echo "$available_formats" | grep -q "$resolution"; then
      ffplay_args+=(-video_size "$resolution")
      break
    fi
  done

  ffplay "${ffplay_args[@]}" -framerate 30 "$WEBCAM_DEVICE" \
    -vf "scale=${target_width}:-1" \
    -window_title "WebcamOverlay" \
    -noborder \
    -fflags nobuffer -flags low_delay \
    -probesize 32 -analyzeduration 0 \
    -loglevel quiet &
  echo "$!" >"$WEBCAM_PID_FILE"
  sleep 1
}

cleanup_webcam() {
  local webcam_pid
  webcam_pid=$(read_pid_file "$WEBCAM_PID_FILE") || {
    rm -f "$WEBCAM_PID_FILE"
    return 0
  }

  kill "$webcam_pid" 2>/dev/null || true
  rm -f "$WEBCAM_PID_FILE"
}

default_resolution() {
  local width height
  read -r width height < <(hyprctl monitors -j | jq -r '.[] | select(.focused == true) | "\(.width) \(.height)"')
  if ((width > 3840 || height > 2160)); then
    echo "3840x2160"
  else
    echo "0x0"
  fi
}

start_screenrecording() {
  local filename="$OUTPUT_DIR/screenrecording-$(date +'%Y-%m-%d_%H-%M-%S').mp4"
  local audio_devices=""
  local audio_args=()

  [[ $DESKTOP_AUDIO == "true" ]] && audio_devices+="default_output"

  if [[ $MICROPHONE_AUDIO == "true" ]]; then
    # Merge audio tracks into one - separate tracks only play one at a time in most players
    [[ -n $audio_devices ]] && audio_devices+="|"
    audio_devices+="default_input"
  fi

  [[ -n $audio_devices ]] && audio_args+=(-a "$audio_devices" -ac aac)

  local resolution="${RESOLUTION:-$(default_resolution)}"

  gpu-screen-recorder -w portal -k auto -s "$resolution" -f 60 -fm cfr -fallback-cpu-encoding yes -o "$filename" "${audio_args[@]}" &
  local pid=$!
  echo "$pid" >"$PID_FILE"

  # Wait for recording to actually start (file appears after portal selection)
  while kill -0 $pid 2>/dev/null && [[ ! -f $filename ]]; do
    sleep 0.2
  done

  if kill -0 $pid 2>/dev/null; then
    echo "$filename" >"$RECORDING_FILE"
    toggle_screenrecording_indicator
    return 0
  fi

  rm -f "$PID_FILE" "$RECORDING_FILE"
  return 1
}

stop_screenrecording() {
  local pid
  pid=$(recording_pid) || return 1

  kill -SIGINT "$pid" 2>/dev/null || true

  # Wait a maximum of 5 seconds to finish before hard killing
  local count=0
  while kill -0 "$pid" 2>/dev/null && ((count < 50)); do
    sleep 0.1
    count=$((count + 1))
  done

  toggle_screenrecording_indicator
  cleanup_webcam

  if kill -0 "$pid" 2>/dev/null; then
    kill -9 "$pid" 2>/dev/null || true
    notify-send "Screen recording error" "Recording process had to be force-killed. Video may be corrupted." -u critical -t 5000
  else
    trim_first_frame
    notify-send "Screen recording saved to $OUTPUT_DIR" -t 2000
  fi

  rm -f "$PID_FILE" "$RECORDING_FILE"
}

trim_first_frame() {
  local latest
  latest=$(cat "$RECORDING_FILE" 2>/dev/null)

  if [[ -n $latest && -f $latest ]]; then
    local trimmed="${latest%.mp4}-trimmed.mp4"
    if ffmpeg -y -ss 0.1 -i "$latest" -c copy "$trimmed" -loglevel quiet 2>/dev/null; then
      mv "$trimmed" "$latest"
    else
      rm -f "$trimmed"
    fi
  fi
}

toggle_screenrecording_indicator() {
  pkill -RTMIN+8 waybar
}

if [[ "$WEBCAM" == "true" ]] && ! command -v v4l2-ctl >/dev/null 2>&1; then
  notify-send "Screen recording error" "v4l2-ctl is required for webcam overlays." -u critical -t 5000
  exit 1
fi

if ! command -v gpu-screen-recorder >/dev/null 2>&1; then
  notify-send "Screen recording error" "gpu-screen-recorder is not installed." -u critical -t 5000
  exit 1
fi

if screenrecording_active >/dev/null; then
  stop_screenrecording
elif [[ $STOP_RECORDING == "true" ]]; then
  exit 1
else
  [[ $WEBCAM == "true" ]] && start_webcam_overlay

  start_screenrecording || cleanup_webcam
fi
