#!/bin/bash
# hyprkarl-menu-uninstall
# Menu for uninstalling packages
#
# Usage:
#   hyprkarl-menu-uninstall [back_cmd]
#
#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

terminal() {
  xdg-terminal-exec --app-id=org.hyprkarl.terminal "$@"
}

back_cmd="$*"

SYSTEM="󰣇 System"
FLATPAK="󰏖 Flatpak"
DOCKER="󰡨 Docker"

CHOICE=$(echo -e "$SYSTEM\n$FLATPAK\n$DOCKER" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Uninstall Packages" \
           -theme ~/.config/rofi/custom-menu.rasi)

case "$CHOICE" in
    "$SYSTEM")  terminal hyprkarl-pkg-remove ;;
    "$FLATPAK") terminal hyprkarl-pkg-flatpak-remove ;;
    "$DOCKER")  hyprkarl-menu-docker-uninstall "hyprkarl-menu-uninstall $back_cmd" ;;
    "")         [[ -n "$back_cmd" ]] && $back_cmd ;;
esac