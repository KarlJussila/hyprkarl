#!/bin/bash
# hyprkarl-menu-defaults
# Menu for setting default applications
#
# Usage:
#   hyprkarl-menu-defaults [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-shell.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-shell.sh"

hyprkarl_parse_back_args "$@"
hyprkarl_build_self_command "$0"

TERMINAL=" Terminal"
EDITOR=" Editor"
SHELL=" Shell"

CHOICE=$(echo -e "$TERMINAL\n$EDITOR\n$SHELL" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Defaults" \
           -theme "$HYPRKARL_ROFI_CUSTOM_THEME")

case "$CHOICE" in
    "$TERMINAL") hyprkarl-menu-terminal --back "${HYPRKARL_SELF_COMMAND[@]}" ;;
    "$EDITOR")   hyprkarl-menu-editor --back "${HYPRKARL_SELF_COMMAND[@]}" ;;
    "$SHELL")    hyprkarl-menu-shell --back "${HYPRKARL_SELF_COMMAND[@]}" ;;
    "")          hyprkarl_run_back "${HYPRKARL_BACK_ARGS[@]}" ;;
esac
