#!/bin/bash

# Power Menu

# Usage:
#   hyprkarl-menu-power [back_cmd]

#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

back_cmd="$*"

LOCK="ď‘– Lock"
SUSPEND="ď†† Suspend"
REBOOT="î«’ Reboot"
SHUTDOWN="ď€‘ Shutdown"

CHOICE=$(echo -e "$LOCK\n$SUSPEND\n$REBOOT\n$SHUTDOWN" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Power Menu" \
           -theme ~/.config/rofi/custom-menu.rasi)

case "$CHOICE" in
    "$LOCK")     hyprkarl-lock ;;
    "$SUSPEND")  hyprkarl-suspend ;;
    "$REBOOT")   hyprkarl-reboot ;;
    "$SHUTDOWN") hyprkarl-shutdown ;;
    "")          [[ -n "$back_cmd" ]] && $back_cmd ;;
esac