#!/bin/bash

# Menu for installing packages

# Usage:
#   hyprkarl-menu-install [back_cmd]

#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

terminal() {
  xdg-terminal-exec --app-id=org.hyprkarl.terminal "$@"
}

back_cmd="$*"

PACMAN="󰣇 Pacman"
AUR=" AUR"
FLATPAK="󰏖 Flatpak"

CHOICE=$(echo -e "$PACMAN\n$AUR\n$FLATPAK" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Install" \
           -theme ~/.config/rofi/custom-menu.rasi)

case "$CHOICE" in
    "$PACMAN")  terminal hyprkarl-pkg-install ;;
    "$AUR")     terminal hyprkarl-pkg-aur-install ;;
    "$FLATPAK") terminal hyprkarl-pkg-flatpak-install ;;
    "")         [[ -n "$back_cmd" ]] && $back_cmd ;;
esac