#!/bin/bash
# hyprkarl-menu-docker-install
# Menu for installing Docker and Docker containers.
# Shows only the Docker install option until Docker is set up, then
# exposes container install options.
#
# Usage:
#   hyprkarl-menu-docker-install [back_cmd]
#
#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

terminal() {
    xdg-terminal-exec --app-id=org.hyprkarl.terminal "$@"
}

back_cmd="$*"

DOCKER="󰡨 Install Docker"
DEGOOG="Degoog"
SEARXNG="SearXNG"
KIWIX="Kiwix"
TRAEFIK="Traefik"

docker_ready() {
    command -v docker &>/dev/null && id -nG "$USER" | grep -qw docker
}

degoog_installed() {
    [[ -f "$HOME/.degoog/docker-compose.yml" ]]
}

searxng_installed() {
    [[ -f "$HOME/.searxng/docker-compose.yaml" ]]
}

kiwix_installed() {
    [[ -f "$HOME/.kiwix/docker-compose.yml" ]]
}

traefik_installed() {
    [[ -f "$HOME/.traefik/docker-compose.yml" ]]
}

if ! docker_ready; then
    CHOICES="$DOCKER"
    MESG="Docker Setup"
else
    CHOICES=""
    degoog_installed || CHOICES+="${CHOICES:+$'\n'}$DEGOOG"
    searxng_installed || CHOICES+="${CHOICES:+$'\n'}$SEARXNG"
    kiwix_installed || CHOICES+="${CHOICES:+$'\n'}$KIWIX"
    traefik_installed || CHOICES+="${CHOICES:+$'\n'}$TRAEFIK"
    MESG="Install Container"
fi

CHOICE=$(echo -e "$CHOICES" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "$MESG" \
           -theme ~/.config/rofi/custom-menu.rasi)

case "$CHOICE" in
    "$DOCKER")  terminal hyprkarl-docker-install ;;
    "$DEGOOG")  terminal hyprkarl-docker-degoog ;;
    "$SEARXNG") terminal hyprkarl-docker-searxng ;;
    "$KIWIX")   terminal hyprkarl-docker-kiwix ;;
    "$TRAEFIK") terminal hyprkarl-docker-traefik ;;
    "")         [[ -n "$back_cmd" ]] && eval "$back_cmd" ;;
esac