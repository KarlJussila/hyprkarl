#!/bin/bash

terminal() {
  xdg-terminal-exec --app-id=org.hyprkarl.terminal "$@"
}

CAFFEINE="о°• Caffeine"
NIGHTLIGHT="пѓ« Nightlight"
SCREEN_RECORD="пЂЅ Screen Record"

CHOICE=$(echo -e "$CAFFEINE\n$NIGHTLIGHT\n$SCREEN_RECORD" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Install" \
           -theme ~/.config/rofi/custom-menu.rasi) \
           || pkill rofi

case "$CHOICE" in
    "$CAFFEINE")      hyprkarl-caffeine ;;
    "$NIGHTLIGHT")    hyprkarl-toggle-nightlight ;;
    "$SCREEN_RECORD") hyprkarl-record-screen ;;
esac