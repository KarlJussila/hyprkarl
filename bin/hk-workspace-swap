#!/bin/bash
# hk-workspace-swap <target_workspace_num>
# Swaps all windows between the current workspace and the target, then focuses target.

target=${1:?usage: hk-workspace-swap <target_num>}
current=$(hyprctl activeworkspace -j | jq '.id')
TEMP="hk-swap-tmp"

if [[ ! "$target" =~ ^[0-9]+$ ]]; then
  echo "hk-workspace-swap: target must be a number" >&2
  exit 1
fi

if [[ "$current" -eq "$target" ]]; then
  exit 0
fi

clients=$(hyprctl clients -j)

# Sort by position so windows are re-inserted in visual order, preserving tiling layout
mapfile -t current_wins < <(jq -r "[.[] | select(.workspace.id == $current)] | sort_by(.at[1], .at[0]) | .[].address" <<< "$clients")
mapfile -t target_wins  < <(jq -r "[.[] | select(.workspace.id == $target)]  | sort_by(.at[1], .at[0]) | .[].address" <<< "$clients")

# Hyprland 0.55+ takes Lua dispatch expressions (hyprctl dispatch wraps the
# argument in hl.dispatch(...)). movetoworkspacesilent -> window.move with
# follow=false; workspace -> focus.
for addr in "${current_wins[@]}"; do
  hyprctl dispatch "hl.dsp.window.move({ workspace = 'name:${TEMP}', follow = false, window = 'address:${addr}' })"
done

for addr in "${target_wins[@]}"; do
  hyprctl dispatch "hl.dsp.window.move({ workspace = ${current}, follow = false, window = 'address:${addr}' })"
done

for addr in "${current_wins[@]}"; do
  hyprctl dispatch "hl.dsp.window.move({ workspace = ${target}, follow = false, window = 'address:${addr}' })"
done

hyprctl dispatch "hl.dsp.focus({ workspace = ${target} })"
