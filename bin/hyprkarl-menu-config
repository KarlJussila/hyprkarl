#!/bin/bash
# hyprkarl-menu-config
# Menu for accessing/editing configs
#
# Usage:
#   hyprkarl-menu-config [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-shell.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-shell.sh"

hyprkarl_parse_back_args "$@"
hyprkarl_build_self_command "$0"

THEME=" Theme"
WALLPAPER=" Wallpaper"
DEFAULTS="󰆓 Defaults"
TIMEZONE="󰇧 Timezone"
FINGERPRINT="󰈷 Fingerprint"

CHOICE=$(echo -e "$THEME\n$WALLPAPER\n$DEFAULTS\n$TIMEZONE\n$FINGERPRINT" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Config" \
           -theme "$HYPRKARL_ROFI_CUSTOM_THEME")

case "$CHOICE" in
    "$THEME")       hyprkarl-menu-theme --back "${HYPRKARL_SELF_COMMAND[@]}" ;;
    "$WALLPAPER")   hyprkarl-menu-wallpaper --back "${HYPRKARL_SELF_COMMAND[@]}" ;;
    "$DEFAULTS")    hyprkarl-menu-defaults --back "${HYPRKARL_SELF_COMMAND[@]}" ;;
    "$TIMEZONE")    hyprkarl_open_terminal hyprkarl-setup-timezone ;;
    "$FINGERPRINT") hyprkarl-menu-fingerprint --back "${HYPRKARL_SELF_COMMAND[@]}" ;;
    "")             hyprkarl_run_back "${HYPRKARL_BACK_ARGS[@]}" ;;
esac
