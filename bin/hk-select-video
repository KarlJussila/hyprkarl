#!/bin/bash
# hk-select-video
# Interactive picker for selecting a video file
#
# Usage:
#   hk-select-video [directory]
#
#   directory   Directory to browse. Defaults to ~/Videos.

start_dir="${1:-$HOME/Videos}"

selected=$(yazi "$start_dir" --chooser-file=/dev/stdout)

[[ -n "$selected" ]] || exit 1

if ! echo "$selected" | grep -qiE '\.(mp4|mkv|mov)$'; then
    echo "Not a supported video file: $selected" >&2
    exit 1
fi

echo "$selected"