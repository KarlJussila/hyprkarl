#!/bin/bash
# hk-brightness-display
# Adjust brightness on the most likely display device and show OSD
#
# Usage:
#   hk-brightness-display <step>

step="${1:-+5%}"

device=""
for backlight_path in \
    /sys/class/backlight/amdgpu_bl* \
    /sys/class/backlight/intel_backlight \
    /sys/class/backlight/acpi_video* \
    /sys/class/backlight/*; do
  if [[ -d "$backlight_path" ]]; then
    device=$(basename "$backlight_path")
    break
  fi
done

if [[ -z "$device" ]]; then
    echo "No display backlight device found." >&2
    exit 1
fi

brightnessctl -d "$device" set "$step" >/dev/null

brightness="$(brightnessctl -d "$device" -m | cut -d',' -f4 | tr -d '%')"

notify-send \
    -h string:x-canonical-private-synchronous:brightness \
    -h int:value:"$brightness" \
    -a "osd-brightness" \
    "Brightness" "${brightness}%" \
    --icon="$(hk-find-icon "display-brightness-symbolic" status actions)"
