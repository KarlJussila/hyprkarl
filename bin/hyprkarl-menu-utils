#!/bin/bash

# Menu for common utilities

# Usage:
#   hyprkarl-menu-utils [back_cmd]

#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

back_cmd="${1:-}"

CAFFEINE=" Caffeine"
NIGHTLIGHT=" Nightlight"
SCREEN_RECORD=" Screen Record"

CHOICE=$(echo -e "$CAFFEINE\n$NIGHTLIGHT\n$SCREEN_RECORD" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Utilities" \
           -theme ~/.config/rofi/custom-menu.rasi) \
           || pkill rofi

case "$CHOICE" in
    "$CAFFEINE")      hyprkarl-caffeine ;;
    "$NIGHTLIGHT")    hyprkarl-nightlight ;;
    "$SCREEN_RECORD") hyprkarl-record-screen ;;
    "")               [[ -n "$back_cmd" ]] && $back_cmd ;;
esac