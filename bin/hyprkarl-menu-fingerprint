#!/bin/bash
# hyprkarl-menu-fingerprint
# Menu for fingerprint management
#
# Usage:
#   hyprkarl-menu-fingerprint [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-shell.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-shell.sh"

# Check if fingerprint auth is set up
is_setup() {
  command -v fprintd-list &>/dev/null && grep -q pam_fprintd.so /etc/pam.d/sudo 2>/dev/null
}

hyprkarl_parse_back_args "$@"

SETUP="󰈷 Setup"
ENROLL="󰈷 Add Fingerprint"
REMOVE=" Remove Fingerprint"
UNINSTALL="󱧖 Uninstall"

# Build menu based on setup state
if is_setup; then
  options=$(echo -e "$ENROLL\n$REMOVE\n$UNINSTALL")
else
  options=$(echo -e "$SETUP")
fi

CHOICE=$(echo "$options" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Fingerprint" \
           -theme "$HYPRKARL_ROFI_CUSTOM_THEME")

case "$CHOICE" in
    "$SETUP")     hyprkarl_open_terminal hyprkarl-fingerprint-setup ;;
    "$ENROLL")    hyprkarl_open_terminal hyprkarl-fingerprint-enroll ;;
    "$REMOVE")    hyprkarl-fingerprint-remove \
                  "$(hyprkarl-fingerprint-select 'Remove Fingerprint')" ;;
    "$UNINSTALL") hyprkarl_open_terminal hyprkarl-fingerprint-setup --remove ;;
    "")           hyprkarl_run_back "${HYPRKARL_BACK_ARGS[@]}" ;;
esac
