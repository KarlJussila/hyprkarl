#!/bin/bash
# hk-menu-fingerprint
# Menu for fingerprint management
#
# Usage:
#   hk-menu-fingerprint [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

ROFI_THEME="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/custom-menu.rasi"

# Check if fingerprint auth is set up
is_setup() {
  command -v fprintd-list &>/dev/null && grep -q pam_fprintd.so /etc/pam.d/sudo 2>/dev/null
}

BACK=()
if [[ "${1:-}" == "--back" ]]; then
  shift; BACK=("$@")
fi

SETUP="󰈷 Setup"
ENROLL="󰈷 Add Fingerprint"
REMOVE=" Remove Fingerprint"
UNINSTALL="󱧖 Uninstall"

# Build menu based on setup state
if is_setup; then
  options=$(echo -e "$ENROLL\n$REMOVE\n$UNINSTALL")
else
  options=$(echo -e "$SETUP")
fi

CHOICE=$(echo "$options" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Fingerprint" \
           -theme "$ROFI_THEME")

case "$CHOICE" in
    "$SETUP")     hk-open-terminal hk-fingerprint setup ;;
    "$ENROLL")    hk-open-terminal hk-fingerprint enroll ;;
    "$REMOVE")    hk-fingerprint remove \
                  "$(hk-fingerprint select 'Remove Fingerprint')" ;;
    "$UNINSTALL") hk-open-terminal hk-fingerprint setup --remove ;;
    "")           (( ${#BACK[@]} )) && "${BACK[@]}" ;;
esac
