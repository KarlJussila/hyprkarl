#!/bin/bash
# hk-menu-install
# Menu for installing packages
#
# Usage:
#   hk-menu-install [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
source "$SCRIPT_DIR/lib/shell.sh"
ROFI_THEME="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/custom-menu.rasi"

BACK=()
if [[ "${1:-}" == "--back" ]]; then
  shift; BACK=("$@")
fi
SELF=("$(basename "$0")")
[[ -n "${BACK[*]}" ]] && SELF+=(--back "${BACK[@]}")  # carry back-chain so submenus can return here

PACMAN="󰣇 Pacman"
AUR=" AUR"
FLATPAK="󰏖 Flatpak"
DOCKER="󰡨 Docker"

CHOICE=$(echo -e "$PACMAN\n$AUR\n$FLATPAK\n$DOCKER" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Install" \
           -theme "$ROFI_THEME")

case "$CHOICE" in
    "$PACMAN")  hyprkarl_open_terminal hk-pkg-install-tui ;;
    "$AUR")     hyprkarl_open_terminal hk-pkg-install-tui --aur ;;
    "$FLATPAK") hyprkarl_open_terminal hk-pkg-install-tui --flatpak ;;
    "$DOCKER")  hk-menu-docker-install --back "${SELF[@]}" ;;
    "")         (( ${#BACK[@]} )) && "${BACK[@]}" ;;
esac
