#!/bin/bash

# Initializes the wallpaper on startup

CURRENT_WALLPAPER_LINK="$HYPRKARL_PATH/config/hyprkarl/current/wallpaper"

if [[ ! -L "$CURRENT_WALLPAPER_LINK" ]]; then
  exit 1
fi

# Wait for hyprpaper socket to be ready
SOCKET="/run/user/$(id -u)/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.hyprpaper.sock"
until [[ -S "$SOCKET" ]]; do
  sleep 0.1
done

WALLPAPER=$(readlink -f "$CURRENT_WALLPAPER_LINK")

hyprctl hyprpaper wallpaper ",$WALLPAPER"

