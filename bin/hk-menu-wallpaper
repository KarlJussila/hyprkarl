#!/bin/bash
# hk-menu-wallpaper
# Submenu for wallpaper management

ROFI_THEME="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/custom-menu.rasi"

SELECT="󰋹 Select"
ADD=" Add"
REMOVE=" Remove"

CHOICE=$(printf '%s\n' "$SELECT" "$ADD" "$REMOVE" |
  rofi -dmenu \
    -p "" \
    -no-custom \
    -mesg "Wallpaper" \
    -theme "$ROFI_THEME")

case "$CHOICE" in
"$SELECT")
  hk-wallpaper set "$(hk-wallpaper select)"
  ;;
"$ADD")
  output_file=$(mktemp) || exit 1
  trap 'rm -f "$output_file"' EXIT
  hk-open-terminal -e bash -c 'hk-select-picture >"$1"' _ "$output_file"
  selected=$(<"$output_file")
  if [[ -n "$selected" ]]; then
    hk-wallpaper add "$selected"
  fi
  ;;
"$REMOVE")
  hk-wallpaper remove "$(hk-wallpaper select '@urgent')"
  ;;
"")
  exit 1
  ;;
esac
