#!/bin/bash
# hyprkarl-launch-or-focus-tui
# Focuses an existing TUI window if one is already open, or launches a new
# one. Prevents duplicate instances of TUI apps like wifi or bluetooth config.
#
# Usage:
#   hyprkarl-launch-or-focus-tui <command> [args...]
#
# Example:
#   hyprkarl-launch-or-focus-tui btop

APP_ID="org.hyprkarl.$(basename "$1")"
LAUNCH_COMMAND="hyprkarl-launch-tui $@"

exec hyprkarl-launch-or-focus "$APP_ID" "$LAUNCH_COMMAND"
