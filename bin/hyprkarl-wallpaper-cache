#!/bin/bash

# Manages the wallpaper thumbnail cache for the current theme
#
# Usage:
#   hyprkarl-wallpaper-cache
#     -> Sync cache: add missing, remove stale
#   hyprkarl-wallpaper-cache --regenerate
#     -> Wipe and regenerate entire cache
#   hyprkarl-wallpaper-cache --single <wallpaper_filename>
#     -> Regenerate one thumbnail

THEME_NAME=$(cat "$HYPRKARL_PATH/config/hyprkarl/current/theme.name")
WALLPAPER_DIR="$HYPRKARL_PATH/config/hyprkarl/current/theme/wallpapers"
CACHE_DIR="$HOME/.cache/hyprkarl/wallpapers/$THEME_NAME"

mkdir -p "$CACHE_DIR"

generate_thumbnail() {
    local img="$1"
    local name=$(basename "$img")
    magick "$img" -strip -thumbnail 500x500^ -gravity center -extent 500x500 "$CACHE_DIR/$name"
}

# Regenerate the cache
if [[ "$1" == "--regenerate" ]]; then
    rm -f "$CACHE_DIR"/*
    for img in "$WALLPAPER_DIR"/*; do
        [ -f "$img" ] || continue
        generate_thumbnail "$img"
    done
    exit 0
fi

# (Re)generate single cached thumbnail
if [[ "$1" == "--single" ]]; then
    if [[ -z "$2" ]]; then
        echo "Usage: hyprkarl-wallpaper-cache --single <wallpaper_filename>" >&2
        exit 1
    fi
    rm -f "$CACHE_DIR/$2"
    generate_thumbnail "$WALLPAPER_DIR/$2"
    exit 0
fi

# Remove cached thumbnails with no corresponding wallpaper
for cached in "$CACHE_DIR"/*; do
    [ -f "$cached" ] || continue
    name=$(basename "$cached")
    if [ ! -f "$WALLPAPER_DIR/$name" ]; then
        rm "$cached"
    fi
done

# Add missing thumbnails
for img in "$WALLPAPER_DIR"/*; do
    [ -f "$img" ] || continue
    name=$(basename "$img")
    if [ ! -f "$CACHE_DIR/$name" ]; then
        generate_thumbnail "$img"
    fi
done