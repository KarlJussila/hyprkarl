#!/bin/bash

# Menu for accessing/editing configs

# Usage:
#   hyprkarl-menu-config [back_cmd]

#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

terminal() {
  xdg-terminal-exec --app-id=org.hyprkarl.terminal "$@"
}

back_cmd="$*"

THEME="îˆ« Theme"
WALLPAPER="ï€¾ Wallpaper"
DEFAULTS="ó°†“ Defaults"
TIMEZONE="ó°‡§ Timezone"
FINGERPRINT="ó°ˆ· Fingerprint"

CHOICE=$(echo -e "$THEME\n$WALLPAPER\n$DEFAULTS\n$TIMEZONE\n$FINGERPRINT" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Config" \
           -theme ~/.config/rofi/custom-menu.rasi)

case "$CHOICE" in
    "$THEME")       hyprkarl-menu-theme "hyprkarl-menu-config${back_cmd:+ $back_cmd}" ;;
    "$WALLPAPER")   hyprkarl-menu-wallpaper "hyprkarl-menu-config${back_cmd:+ $back_cmd}" ;;
    "$DEFAULTS")    hyprkarl-menu-defaults "hyprkarl-menu-config${back_cmd:+ $back_cmd}" ;;
    "$TIMEZONE")    terminal hyprkarl-setup-timezone ;;
    "$FINGERPRINT") hyprkarl-menu-fingerprint "hyprkarl-menu-config${back_cmd:+ $back_cmd}" ;;
    "")             [[ -n "$back_cmd" ]] && $back_cmd ;;
esac