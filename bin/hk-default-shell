#!/bin/bash
# hk-default-shell
# Set a shell as the user's default shell
#
# Usage:
#   hk-default-shell <shell>
#
#   shell   One of: fish, zsh, bash

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_success() { echo -e "${GREEN}$1${NC}"; }
print_error() { echo -e "${RED}$1${NC}"; }
print_info() { echo -e "${YELLOW}$1${NC}"; }

if (($# == 0)); then
  print_error "No shell specified."
  print_info "Usage: hk-default-shell [fish|zsh|bash]"
  exit 1
fi

shell="$1"

# Map shell name to binary path
case "$shell" in
fish) shell_path="/usr/bin/fish" ;;
zsh)  shell_path="/usr/bin/zsh" ;;
bash) shell_path="/usr/bin/bash" ;;
*)
  print_error "Unknown shell: $shell"
  print_info "Valid options: fish, zsh, bash"
  exit 1
  ;;
esac

# Install shell if not present
if ! pacman -Q "$shell" &>/dev/null; then
  print_info "\nInstalling $shell..."
  if ! hk-pkg install "$shell"; then
    print_error "\nFailed to install $shell."
    hk-show-done && exit 1
  fi
fi

# Change default shell
print_info "\nChanging default shell to $shell..."
if chsh -s "$shell_path"; then
  print_success "\nDefault shell changed to $shell."
  print_info "This will take effect on next login."
else
  print_error "\nFailed to change default shell."
  hk-show-done && exit 1
fi

hk-show-done
