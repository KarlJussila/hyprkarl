#!/bin/bash
# hyprkarl-mic
# Controls microphone mute state and shows OSD
#
# Usage:
#   hyprkarl-mic [toggle|mute|unmute]
#
#   (none)    Display current mute state without changing it.
#   toggle    Switch to whichever state is not current.
#   mute      Mute the microphone. No-op if already muted.
#   unmute    Unmute the microphone. No-op if already unmuted.

ICON_MIC_ACTIVE=$(hyprkarl-find-icon "audio-input-microphone-symbolic" status actions devices)
ICON_MIC_MUTED=$(hyprkarl-find-icon "microphone-sensitivity-muted-symbolic" status actions devices)

case "${1:-}" in
    toggle) wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle ;;
    mute)   wpctl set-mute @DEFAULT_AUDIO_SOURCE@ 1 ;;
    unmute) wpctl set-mute @DEFAULT_AUDIO_SOURCE@ 0 ;;
    "")     ;;
    *)      echo "Usage: $(basename "$0") [toggle|mute|unmute]" >&2; exit 1 ;;
esac

mic_muted=$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | grep -c MUTED)

if (( mic_muted )); then
    icon="$ICON_MIC_MUTED"
    summary="Mic Muted"
else
    icon="$ICON_MIC_ACTIVE"
    summary="Mic Active"
fi

notify-send \
    -h string:x-canonical-private-synchronous:microphone \
    -h int:value:0 \
    -a "osd-volume" \
    "$summary" "" \
    --icon="$icon"