#!/bin/bash

# Adds a wallpaper to the current theme
# Usage: hyprkarl-wallpaper-add <path_to_image>

WALLPAPER_DIR="$HYPRKARL_PATH/config/hyprkarl/current/theme/wallpapers"

source_path="$1"

if [[ -z "$source_path" ]]; then
    echo "Usage: hyprkarl-wallpaper-add <path_to_image>" >&2
    exit 1
fi

if [[ ! -f "$source_path" ]]; then
    echo "File not found: $source_path" >&2
    exit 1
fi

wallpaper_name=$(basename "$source_path")

if ! echo "$wallpaper_name" | grep -qiE '\.(jpg|jpeg|png|webp)$'; then
    echo "Unsupported file type: $wallpaper_name" >&2
    echo "Supported formats: jpg, jpeg, png, webp" >&2
    exit 1
fi

cp -L "$source_path" "$WALLPAPER_DIR/$wallpaper_name"
hyprkarl-wallpaper-cache --single "$wallpaper_name"
hyprkarl-wallpaper-set "$wallpaper_name"