#!/bin/bash
# hyprkarl-menu-power-profile
# Menu for setting the system power profile via power-profiles-daemon
#
# Usage:
#   hyprkarl-menu-power-profile [back_cmd]
#
#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              If omitted, dismissing the menu does nothing.

back_cmd="$*"

CURRENT=$(powerprofilesctl get)


label() {
    local profile="$1" icon="$2"
    [[ "$profile" == "$CURRENT" ]] && echo "箚꽟 ${2#* }" || echo "$icon"
}

POWER_SAVER=$(label power-saver "茶뒩 Power Saver")
BALANCED=$(label balanced "箚뿊 Balanced")
PERFORMANCE=$(label performance "茶릩 Performance")

CHOICE=$(echo -e "$POWER_SAVER\n$BALANCED\n$PERFORMANCE" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Power Profile" \
           -theme ~/.config/rofi/custom-menu.rasi)

case "$CHOICE" in
    "$POWER_SAVER")   powerprofilesctl set power-saver ;;
    "$BALANCED")      powerprofilesctl set balanced ;;
    "$PERFORMANCE")   powerprofilesctl set performance ;;
    "")               [[ -n "$back_cmd" ]] && $back_cmd ;;
esac