#!/bin/bash

THEME=" Theme"
TERMINAL=" Terminal"
EDITOR=" Editor"

CHOICE=$(echo -e "$THEME\n$TERMINAL\n$EDITOR" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Config" \
           -theme ~/.config/rofi/custom-menu.rasi) \
           || pkill rofi

case "$CHOICE" in
    "$TERMINAL") hyprkarl-menu-terminal ;;
    "$EDITOR")   hyprkarl-menu-editor ;;
    "$THEME")    hyprkarl-menu-theme ;;
esac