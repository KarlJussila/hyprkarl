#!/bin/bash
# hyprkarl-menu-docker-uninstall
# Menu for removing Docker containers.
#
# Usage:
#   hyprkarl-menu-docker-uninstall [back_cmd]
#
#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

terminal() {
    xdg-terminal-exec --app-id=org.hyprkarl.terminal "$@"
}

back_cmd="$*"

DEGOOG="Degoog"
SEARXNG="SearXNG"
KIWIX="Kiwix"
TRAEFIK="Traefik"

CHOICES=""
degoog_installed() {
    [[ -f "$HOME/.degoog/docker-compose.yml" ]]
}

searxng_installed() {
    [[ -f "$HOME/.searxng/docker-compose.yaml" ]]
}

kiwix_installed() {
    [[ -f "$HOME/.kiwix/docker-compose.yml" ]]
}

traefik_installed() {
    [[ -f "$HOME/.traefik/docker-compose.yml" ]]
}

degoog_installed && CHOICES+="${CHOICES:+$'\n'}$DEGOOG"
searxng_installed && CHOICES+="${CHOICES:+$'\n'}$SEARXNG"
kiwix_installed && CHOICES+="${CHOICES:+$'\n'}$KIWIX"
traefik_installed && CHOICES+="${CHOICES:+$'\n'}$TRAEFIK"

if [[ -z "$CHOICES" ]]; then
    CHOICES="(nothing to remove)"
    MESG="No containers installed"
else
    MESG="Remove container"
fi

CHOICE=$(echo -e "$CHOICES" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "$MESG" \
           -theme ~/.config/rofi/custom-menu.rasi)

case "$CHOICE" in
    "$DEGOOG")  terminal hyprkarl-docker-degoog --remove ;;
    "$SEARXNG") terminal hyprkarl-docker-searxng --remove ;;
    "$KIWIX")   terminal hyprkarl-docker-kiwix --remove ;;
    "$TRAEFIK") terminal hyprkarl-docker-traefik --remove ;;
    "")         [[ -n "$back_cmd" ]] && eval "$back_cmd" ;;
esac