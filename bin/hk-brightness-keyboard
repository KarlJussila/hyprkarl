#!/bin/bash
# hk-brightness-keyboard
# Adjust keyboard backlight brightness and show OSD
#
# Usage:
#   hk-brightness-keyboard <up|down>

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
source "$SCRIPT_DIR/lib/shell.sh"

ICON_KEYBOARD=$(hk-find-icon "keyboard-brightness-symbolic" status actions)

direction="${1:-up}"

device=$(hyprkarl_find_keyboard_backlight)

if [[ -z "$device" ]]; then
    echo "No keyboard backlight device found" >&2
    exit 1
fi

max_brightness="$(brightnessctl -d "$device" max)"
current_brightness="$(brightnessctl -d "$device" get)"

if [[ "$direction" == "up" ]]; then
    new_brightness=$(( current_brightness + 1 ))
    (( new_brightness > max_brightness )) && new_brightness=$max_brightness
else
    new_brightness=$(( current_brightness - 1 ))
    (( new_brightness < 0 )) && new_brightness=0
fi

brightnessctl -d "$device" set "$new_brightness" >/dev/null

percent=$(( new_brightness * 100 / max_brightness ))

notify-send \
    -h string:x-canonical-private-synchronous:brightness-keyboard \
    -h int:value:"$percent" \
    -a "osd-brightness" \
    "Keyboard Brightness" "${percent}%" \
    --icon="$ICON_KEYBOARD"
