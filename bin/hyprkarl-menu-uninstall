#!/bin/bash
# hyprkarl-menu-uninstall
# Menu for uninstalling packages
#
# Usage:
#   hyprkarl-menu-uninstall [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-shell.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-shell.sh"

hyprkarl_parse_back_args "$@"
hyprkarl_build_self_command "$0"

SYSTEM="󰣇 System"
FLATPAK="󰏖 Flatpak"
DOCKER="󰡨 Docker"

CHOICE=$(echo -e "$SYSTEM\n$FLATPAK\n$DOCKER" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Uninstall Packages" \
           -theme "$HYPRKARL_ROFI_CUSTOM_THEME")

case "$CHOICE" in
    "$SYSTEM")  hyprkarl_open_terminal hyprkarl-pkg-remove ;;
    "$FLATPAK") hyprkarl_open_terminal hyprkarl-pkg-flatpak-remove ;;
    "$DOCKER")  hyprkarl-menu-docker-uninstall --back "${HYPRKARL_SELF_COMMAND[@]}" ;;
    "")         hyprkarl_run_back "${HYPRKARL_BACK_ARGS[@]}" ;;
esac
