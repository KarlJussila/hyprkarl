#!/bin/bash
# hk-notify-window-class
# Send a notification with class/title, copy full JSON to clipboard

WINDOW_JSON=$(hyprctl activewindow -j 2>/dev/null)

if [[ -z "$WINDOW_JSON" ]]; then
    notify-send "Active Window" "No active window"
    exit 0
fi

CLASS=$(echo "$WINDOW_JSON" | jq -r '.class // "N/A"')
TITLE=$(echo "$WINDOW_JSON" | jq -r '.title // "N/A"')

notify-send "Active Window" "$(printf 'Class: %s\nTitle: %s' "$CLASS" "$TITLE")"
echo "$WINDOW_JSON" | wl-copy
