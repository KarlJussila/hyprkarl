#!/bin/bash
# hk-menu-install
# Menu for installing packages

ROFI_THEME="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/custom-menu.rasi"

PACMAN="¾░úç Pacman"
AUR="´Éü AUR"
FLATPAK="¾░Åû Flatpak"
DOCKER="¾░í¿ Docker"

relaunch_menu() { exec "$0"; }

CHOICE=$(echo -e "$PACMAN\n$AUR\n$FLATPAK\n$DOCKER" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Install" \
           -theme "$ROFI_THEME")

case "$CHOICE" in
    "$PACMAN")  hk-launch-tui hk-pkg-install-tui ;;
    "$AUR")     hk-launch-tui hk-pkg-install-tui --aur ;;
    "$FLATPAK") hk-launch-tui hk-pkg-install-tui --flatpak ;;
    "$DOCKER")  hk-menu-docker-install || relaunch_menu ;;
    "")         exit 1 ;;
esac

exit 0
