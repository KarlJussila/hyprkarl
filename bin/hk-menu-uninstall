#!/bin/bash
# hk-menu-uninstall
# Menu for uninstalling packages

ROFI_THEME="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/custom-menu.rasi"

SYSTEM="箚즵 System"
FLATPAK="箚룚 Flatpak"
DOCKER="箚〃 Docker"

relaunch_menu() { exec "$0"; }

CHOICE=$(echo -e "$SYSTEM\n$FLATPAK\n$DOCKER" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Uninstall Packages" \
           -theme "$ROFI_THEME")

case "$CHOICE" in
    "$SYSTEM")  hk-open-terminal hk-pkg-remove-tui ;;
    "$FLATPAK") hk-open-terminal hk-pkg-remove-tui --flatpak ;;
    "$DOCKER")  hk-menu-docker-uninstall || relaunch_menu ;;
    "")         exit 1 ;;
esac

exit 0
