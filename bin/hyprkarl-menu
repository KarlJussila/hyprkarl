#!/bin/bash

LAUNCH="󱓟 Launch"
INSTALL=" Install"
UNINSTALL=" Uninstall"
UTILS=" Utils"
POWER=" Power"

CHOICE=$(echo -e "$LAUNCH\n$INSTALL\n$UNINSTALL\n$UTILS\n$POWER" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Main Menu" \
           -theme ~/.config/rofi/custom-menu.rasi) \
           || pkill rofi

case "$CHOICE" in
    "$LAUNCH")    hyprkarl-menu-launcher ;;
    "$INSTALL")   hyprkarl-menu-install ;;
    "$UNINSTALL") hyprkarl-menu-uninstall ;;
    "$UTILS")     hyprkarl-menu-utils ;;
    "$POWER")     hyprkarl-menu-power ;;
esac