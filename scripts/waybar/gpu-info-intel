#!/usr/bin/env bash
# gpu-info-intel
# Intel-specific GPU info for Waybar.
#
# Usage:
#   gpu-info-intel <card> <name>

card="$1"
name="$2"

usage_intel() {
    local busy_file
    busy_file=$(find "/sys/class/drm/${card}/device" \
        -path "*/engines/rcs*/busy" -o \
        -path "*/engines/render*/busy" 2>/dev/null | head -1)
    [[ -z "$busy_file" || ! -r "$busy_file" ]] && { echo "N/A"; return; }

    local busy1 busy2
    busy1=$(< "$busy_file")
    sleep 0.5
    busy2=$(< "$busy_file")

    awk "BEGIN{
        delta = $busy2 - $busy1
        pct = (delta / 500000000) * 100
        if (pct < 0) pct = 0
        if (pct > 100) pct = 100
        printf \"%.0f%%\n\", pct
    }"
}

vram_intel() {
    local used_file="/sys/class/drm/${card}/device/mem_info_vram_used"
    local total_file="/sys/class/drm/${card}/device/mem_info_vram_total"
    # Only Arc discrete GPUs have dedicated VRAM via sysfs
    [[ -r "$used_file" && -r "$total_file" ]] || { echo "N/A"; return; }
    local used total
    used=$(< "$used_file")
    total=$(< "$total_file")
    awk "BEGIN{printf \"%.1f/%.1f GiB\n\", $used/1073741824, $total/1073741824}"
}

usage=$(usage_intel)
vram=$(vram_intel)

if [[ "$usage" == "N/A" && "$vram" == "N/A" ]]; then
    echo '{"text":"N/A","alt":"N/A","tooltip":"'"${name}"'"}'
    exit 1
fi

echo "{\"text\":\"${usage}\",\"alt\":\"${usage} | ${vram}\",\"tooltip\":\"${name}\"}"
