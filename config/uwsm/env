# Changes require a restart to take effect.

# Ensure hyprkarl bins are in the path
export HYPRKARL_PATH=$HOME/.local/share/hyprkarl
export PATH=$HYPRKARL_PATH/bin:$PATH

# Add flatpak directories
export XDG_DATA_DIRS="/var/lib/flatpak/exports/share:$HOME/.local/share/flatpak/exports/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"

# Qt theme
export QT_QPA_PLATFORMTHEME=qt5ct

# Set default terminal and editor
source ~/.config/uwsm/default

# Set wifitui theme
export WIFITUI_THEME="$HOME/.config/hyprkarl/current/theme/wifitui.toml"