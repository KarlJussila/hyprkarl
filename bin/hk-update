#!/bin/bash
# hk-update
# Apply updates to hyprkarl after merging upstream changes.
#
# Usage:
#   hk-update check
#   hk-update dotfiles
#   hk-update packages
#   hk-update system
#   hk-update all

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
ACTION_DIR="$SCRIPT_DIR/lib/update"

usage() {
  cat <<'EOF'
Usage:
  hk-update check               Report what would change (no side effects)
  hk-update dotfiles [--force]  Restow config files and remove stale symlinks
  hk-update dotfiles --adopt    Adopt conflicting ~/.config files into the repo for review
  hk-update packages            Install new required packages, prompt for dropped ones
  hk-update system              Re-run system-level setup
  hk-update all                 Run dotfiles, packages, and system in sequence
EOF
}

action=${1:-}
shift || true

case "$action" in
  all)
    "$ACTION_DIR/dotfiles.sh" || exit 1
    "$ACTION_DIR/packages.sh" || exit 1
    "$ACTION_DIR/system.sh"   || exit 1
    exit 0
    ;;
  check|dotfiles|packages|system)
    ;;
  ""|-h|--help|help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac

exec "$ACTION_DIR/$action.sh" "$@"
