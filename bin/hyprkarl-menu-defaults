#!/bin/bash
# hyprkarl-menu-defaults
# Menu for setting default applications
#
# Usage:
#   hyprkarl-menu-defaults [back_cmd]
#
#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

back_cmd="$*"

TERMINAL="´Æë Terminal"
EDITOR="´üä Editor"
SHELL="¯Üæ Shell"

CHOICE=$(echo -e "$TERMINAL\n$EDITOR\n$SHELL" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Defaults" \
           -theme ~/.config/rofi/custom-menu.rasi)

case "$CHOICE" in
    "$TERMINAL") hyprkarl-menu-terminal "hyprkarl-menu-defaults${back_cmd:+ $back_cmd}" ;;
    "$EDITOR")   hyprkarl-menu-editor "hyprkarl-menu-defaults${back_cmd:+ $back_cmd}" ;;
    "$SHELL")    hyprkarl-menu-shell "hyprkarl-menu-defaults${back_cmd:+ $back_cmd}" ;;
    "")          [[ -n "$back_cmd" ]] && $back_cmd ;;
esac