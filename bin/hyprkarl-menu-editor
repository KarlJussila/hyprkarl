#!/bin/bash
# hyprkarl-menu-editor
# Menu for selecting a default text editor
#
# Usage:
#   hyprkarl-menu-editor [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-shell.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-shell.sh"

hyprkarl_parse_back_args "$@"

NVIM=" Neovim"
VIM=" Vim"
NANO=" Nano"
MICRO="μ Micro"
VSCODIUM=" VSCodium"

CHOICE=$(echo -e "$NVIM\n$VIM\n$NANO\n$MICRO\n$VSCODIUM" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Default Editor" \
           -theme "$HYPRKARL_ROFI_CUSTOM_THEME")

case "$CHOICE" in
    "$NVIM")     hyprkarl-default-editor nvim ;;
    "$VIM")      hyprkarl-default-editor vim ;;
    "$NANO")     hyprkarl-default-editor nano ;;
    "$MICRO")    hyprkarl-default-editor micro ;;
    "$VSCODIUM") hyprkarl-default-editor vscodium ;;
    "")          hyprkarl_run_back "${HYPRKARL_BACK_ARGS[@]}" ;;
esac
