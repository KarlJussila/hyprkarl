#!/bin/bash
# hyprkarl-docker-degoog
# Installs or removes the Degoog Docker container.
#
# Usage:
#   hyprkarl-docker-degoog [--remove]

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-docker.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-docker.sh"

hyprkarl_docker_run_service_command degoog "$@"
