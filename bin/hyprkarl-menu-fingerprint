#!/bin/bash

# Menu for fingerprint management

# Usage:
#   hyprkarl-menu-fingerprint [back_cmd]

#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

terminal() {
  xdg-terminal-exec --app-id=org.hyprkarl.terminal "$@"
}

# Check if fingerprint auth is set up
is_setup() {
  command -v fprintd-list &>/dev/null && grep -q pam_fprintd.so /etc/pam.d/sudo 2>/dev/null
}

back_cmd="${1:-}"

SETUP="󰈷 Setup"
ENROLL="󰈷 Add Fingerprint"
REMOVE=" Remove Fingerprint"
UNINSTALL="󱧖 Uninstall"

# Build menu based on setup state
if is_setup; then
  options=$(echo -e "$ENROLL\n$REMOVE\n$UNINSTALL")
else
  options=$(echo -e "$SETUP")
fi

CHOICE=$(echo "$options" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Fingerprint" \
           -theme ~/.config/rofi/custom-menu.rasi) \
           || pkill rofi

case "$CHOICE" in
    "$SETUP")     terminal hyprkarl-fingerprint-setup ;;
    "$ENROLL")    terminal hyprkarl-fingerprint-enroll ;;
    "$REMOVE")    hyprkarl-fingerprint-remove \
                  "$(hyprkarl-fingerprint-select 'Remove Fingerprint')" ;;
    "$UNINSTALL") terminal hyprkarl-fingerprint-setup --remove ;;
    "")           [[ -n "$back_cmd" ]] && $back_cmd ;;
esac