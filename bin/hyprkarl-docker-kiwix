#!/bin/bash
# hyprkarl-docker-kiwix
# Installs or removes the Kiwix Docker container.
#
# Usage:
#   hyprkarl-docker-kiwix           Install Kiwix
#   hyprkarl-docker-kiwix --remove  Stop, remove, and delete all Kiwix data

set -uo pipefail

KIWIX_DIR="$HOME/.kiwix"
DATA_DIR="$KIWIX_DIR/data"
COMPOSE_FILE="$KIWIX_DIR/docker-compose.yml"
HOSTS_ENTRY="127.0.0.1 kiwix.local"

ensure_network() {
    docker network inspect traefik-proxy &>/dev/null \
        || docker network create traefik-proxy
}

remove() {
    if [[ ! -f "$COMPOSE_FILE" ]]; then
        gum log --level error "No Kiwix installation found at $KIWIX_DIR, nothing to do."
        exit 0
    fi

    gum log --level warn "This will stop the Kiwix container and permanently delete all data in $KIWIX_DIR."
    if ! gum confirm "Continue?"; then
        gum log --level error "Aborted."
        exit 0
    fi

    gum log --level info "Stopping and removing Kiwix stack..."
    docker compose -f "$COMPOSE_FILE" down --rmi all --volumes

    gum log --level info "Deleting $KIWIX_DIR..."
    sudo rm -rf "$KIWIX_DIR"

    gum log --level info "Removing /etc/hosts entry..."
    sudo sed -i "/^$HOSTS_ENTRY$/d" /etc/hosts
}

install() {
    gum log --level info "Creating Kiwix directories..."
    mkdir -p "$DATA_DIR"

    gum log --level info "Ensuring traefik-proxy network exists..."
    ensure_network

    gum log --level info "Writing docker-compose.yml..."
    cat > "$COMPOSE_FILE" << 'EOF'
services:
  kiwix:
    image: ghcr.io/kiwix/kiwix-serve:latest
    volumes:
      - ./data:/data
    ports:
      - "127.0.0.1:8888:8080"
    command: "*.zim"
    restart: unless-stopped
    networks:
      - traefik-proxy
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.kiwix.rule=Host(`kiwix.local`)"
      - "traefik.http.routers.kiwix.entrypoints=web"
      - "traefik.http.services.kiwix.loadbalancer.server.port=8080"

networks:
  traefik-proxy:
    external: true
EOF

    gum log --level info "Adding /etc/hosts entry..."
    if ! grep -qF "$HOSTS_ENTRY" /etc/hosts; then
        echo "$HOSTS_ENTRY" | sudo tee -a /etc/hosts > /dev/null
    fi

    gum log --level info "Starting Kiwix..."
    docker compose -f "$COMPOSE_FILE" up -d

    gum log --level info "Kiwix is available at http://kiwix.local (requires Traefik) or http://localhost:8888"
    gum log --level warn "Place ZIM files in $DATA_DIR to make them available. Kiwix will restart repeatedly until a ZIM file is present."
}

case "${1:-}" in
    --remove) remove && hyprkarl-show-done ;;
    "")       install && hyprkarl-show-done ;;
    *)        gum log --level error "Usage: hyprkarl-docker-kiwix [--remove]"; exit 1 ;;
esac