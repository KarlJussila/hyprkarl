#!/bin/bash
# hyprkarl-docker-kiwix
# Installs or removes the Kiwix Docker container.
#
# Usage:
#   hyprkarl-docker-kiwix [--remove]

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-docker.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-docker.sh"

hyprkarl_docker_run_service_command kiwix "$@"
