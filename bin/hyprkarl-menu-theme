#!/bin/bash

# Menu for selecting a theme

CHOICE=$(hyprkarl-theme-list \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Theme" \
           -theme ~/.config/rofi/custom-menu.rasi) \
           || pkill rofi

if [[ -n "$CHOICE" ]]; then
  hyprkarl-theme-set "$CHOICE"
fi