#!/bin/bash

# Menu for accessing/editing configs

terminal() {
  xdg-terminal-exec --app-id=org.hyprkarl.terminal "$@"
}

THEME=" Theme"
WALLPAPER=" Wallpaper"
TERMINAL=" Terminal"
EDITOR=" Editor"
TIMEZONE="󰇧 Timezone"

CHOICE=$(echo -e "$THEME\n$WALLPAPER\n$TERMINAL\n$EDITOR\n$TIMEZONE" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Config" \
           -theme ~/.config/rofi/custom-menu.rasi) \
           || pkill rofi

case "$CHOICE" in
    "$THEME")    hyprkarl-menu-theme ;;
    "$WALLPAPER") hyprkarl-menu-wallpaper ;;
    "$TERMINAL") hyprkarl-menu-terminal ;;
    "$EDITOR")   hyprkarl-menu-editor ;;
    "$TIMEZONE") terminal hyprkarl-setup-timezone ;;
esac