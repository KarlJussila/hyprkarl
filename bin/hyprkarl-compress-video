#!/bin/bash
# hyprkarl-compress-video
# Compresses a video file to a target file size using two-pass encoding.
#
# Usage:
#   hyprkarl-video-compress [input] [target_size] [options]
#
#   input        Path to source video. Prompted via gum if omitted.
#   target_size  Target file size (e.g. 10M, 50M). Prompted if omitted.
#
# Options:
#   -a, --audio-bitrate <kbps>   Audio bitrate to reserve (e.g. 128). Prompted if omitted.
#   -n, --non-interactive        Skip all prompts, use defaults (10M, 64k audio).
#
# Encoding strategy:
#   Attempt 1 encodes at (target_video_bitrate * INITIAL_SAFETY_MARGIN%).
#   If the result exceeds the target size, attempt 2 scales the bitrate down
#   proportionally with a more aggressive margin to guarantee an undershoot.
#   If the required bitrate falls below MIN_VIDEO_BITRATE, the video is
#   downscaled to DOWNSCALE_WIDTH before encoding.

# --- Tuning ---
MIN_VIDEO_BITRATE=300       # kbps — if required bitrate falls below this, downscale instead
TARGET_FPS=30               # fps to target during encoding
DOWNSCALE_WIDTH=640         # width in pixels to downscale to when bitrate is too low
INITIAL_SAFETY_MARGIN=98    # percent of target bitrate to use on first attempt
CORRECTION_SAFETY_MARGIN=90 # percent to use on second attempt — undershoots to guarantee fit
DEBUG=${DEBUG:-0}

# Redirect output to /dev/null unless DEBUG is set
[[ "$DEBUG" -ne 0 ]] && ff_out="/dev/stderr" || ff_out="/dev/null"

# --- Logging ---
dbg()  { [[ "$DEBUG" -ne 0 ]] && gum log --level debug "$*"; }
info() { gum log --level info "$*"; }
warn() { gum log --level warn "$*"; }
error(){ gum log --level error "$*"; exit 1; }


# =============================================================================
# Argument parsing
# =============================================================================

parse_args() {
    input=""
    target_size=""
    audio_bitrate_to_reserve=""
    non_interactive=0

    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            --audio-bitrate|-a)
                if [[ -n "${2:-}" && ! "$2" =~ ^- ]]; then
                    audio_bitrate_to_reserve="$2"
                    shift 2
                else
                    error "--audio-bitrate requires a value (e.g., 128)."
                fi
                ;;
            --non-interactive|-n)
                non_interactive=1
                shift
                ;;
            *)
                if [[ -z "$input" ]]; then
                    input="$1"
                elif [[ -z "$target_size" ]]; then
                    target_size="$1"
                else
                    error "Unknown argument: $1"
                fi
                shift ;;
        esac
    done
}


# =============================================================================
# Prompts
# =============================================================================

prompt_for_input_file() {
    input=$(hyprkarl-select-video)
    [[ -n "$input" ]] || error "No file selected."
}

prompt_for_target_size() {
    target_size=$(gum input --prompt="Target size: " --placeholder="e.g. 50M")
    [[ -n "$target_size" ]] || error "No target size provided."
}

prompt_for_audio_bitrate() {
    command -v gum >/dev/null 2>&1 || error "gum not found; supply --audio-bitrate as argument."
    local choice
    choice=$(gum choose --header="Select audio quality:" \
        "Off (0)" \
        "Low (64k)" \
        "Medium (96k)" \
        "High (128k)" \
        "Audiophile (192k)")
    [[ -n "$choice" ]] || error "No audio option selected."
    audio_bitrate_to_reserve=$(echo "$choice" | awk '{print $2}' | tr -d 'k()')
}

resolve_inputs() {
    if (( non_interactive )); then
        [[ -z "$target_size" ]]              && { target_size="10M";  info "Non-interactive: using default target size $target_size."; }
        [[ -z "$audio_bitrate_to_reserve" ]] && { audio_bitrate_to_reserve="64"; info "Non-interactive: using default audio bitrate ${audio_bitrate_to_reserve}k."; }
    else
        [[ -z "$input" ]]                    && prompt_for_input_file
        [[ -z "$target_size" ]]              && prompt_for_target_size
        [[ -z "$audio_bitrate_to_reserve" ]] && prompt_for_audio_bitrate
    fi

    [[ -f "$input" ]] || error "Invalid file: $input"

    if ! [[ "$audio_bitrate_to_reserve" =~ ^[0-9]+$ ]]; then
        error "Invalid audio bitrate: '$audio_bitrate_to_reserve'. Must be a number."
    fi

    # Normalize size input: uppercase and strip trailing B (e.g. MB -> M) for numfmt
    target_size="${target_size^^}"
    target_size="${target_size%B}"
    size_bytes_target=$(numfmt --from=iec "$target_size") || error "Invalid size format: $target_size"
}


# =============================================================================
# Source probing
# =============================================================================

probe_source() {
    info "Probing source file..."

    duration_raw=$(ffprobe -v error -show_entries format=duration \
        -of default=noprint_wrappers=1:nokey=1 "$input")
    duration=${duration_raw%.*}
    [[ "$duration" =~ ^[0-9]+$ ]] || error "Could not determine duration."

    # Parse fractional frame rate (e.g. 30000/1001) into an integer
    fps_raw=$(ffprobe -v 0 -select_streams v:0 \
        -show_entries stream=r_frame_rate -of csv=p=0 "$input")
    fps=$(echo "$fps_raw" | awk -F/ '{ if ($2==0) print int($1); else print int($1/$2) }')
    [[ "$fps" =~ ^[0-9]+$ ]] || fps=$TARGET_FPS

    src_w=$(ffprobe -v error -select_streams v:0 \
        -show_entries stream=width -of csv=p=0 "$input" 2>/dev/null || echo "")

    # Check whether the source has an audio stream
    has_audio=0
    if ffprobe -v error -select_streams a \
        -show_entries stream=codec_name -of csv=p=0 "$input" | grep -q .; then
        has_audio=1
    fi

    dbg "duration=${duration}s fps=${fps} src_w=${src_w} has_audio=${has_audio}"
}


# =============================================================================
# Encoding parameter calculation
# =============================================================================

calculate_encoding_params() {
    # Total available bitrate across the entire file duration
    local target_total_kbps=$(( (size_bytes_target * 8) / duration / 1000 ))

    # Reserve audio bitrate from the budget, leaving the rest for video
    target_video_kbps=$target_total_kbps
    (( has_audio )) && target_video_kbps=$(( target_total_kbps - audio_bitrate_to_reserve ))

    # If the required video bitrate is too low for acceptable quality, downscale instead
    scale_filter=""
    if (( target_video_kbps < MIN_VIDEO_BITRATE )); then
        warn "Required video bitrate ${target_video_kbps}k is below minimum ${MIN_VIDEO_BITRATE}k. Downscaling to ${DOWNSCALE_WIDTH}px."
        scale_filter="-vf scale=${DOWNSCALE_WIDTH}:-2"
    fi

    # Build audio options for ffmpeg
    audio_opts="-an"
    if (( audio_bitrate_to_reserve )); then
        if (( has_audio )); then
            audio_opts="-c:a aac -b:a ${audio_bitrate_to_reserve}k -ac 1"
        else
            warn "Audio bitrate requested but source has no audio stream. Ignoring."
        fi
    fi

    dbg "target_video_kbps=${target_video_kbps} scale_filter='${scale_filter}' audio_opts='${audio_opts}'"
}


# =============================================================================
# Encoding
# =============================================================================

# Two-pass encode: pass 1 analyzes the video, pass 2 produces the output.
# Returns 0 if the result is at or below the target size, 1 otherwise.
encode_video() {
    local video_bitrate_kbps="$1"
    local log_dir="$HOME/.cache/hyprkarl/ffmpeg-logs"
    mkdir -p "$log_dir"

    dbg "Encoding at ${video_bitrate_kbps}k — scale='${scale_filter}' audio='${audio_opts}'"
    (
        cd "$log_dir"
        ffmpeg -y -i "$input" $scale_filter -r "$TARGET_FPS" \
            -c:v libx264 -b:v "${video_bitrate_kbps}k" -pass 1 -an -f null /dev/null >"$ff_out" 2>&1
        ffmpeg -y -i "$input" $scale_filter -r "$TARGET_FPS" \
            -c:v libx264 -b:v "${video_bitrate_kbps}k" -pass 2 $audio_opts "$output" >"$ff_out" 2>&1
    )

    actual_size=$(stat -c%s "$output")
    info "Result: $(numfmt --to=iec "$actual_size") / $(numfmt --to=iec "$size_bytes_target") target."

    (( actual_size <= size_bytes_target ))
}

run_encode_attempts() {
    local ext="${input##*.}"
    local base="${input%.*}"
    output="${base}_compressed.${ext}"

    local attempt1_kbps=$(( target_video_kbps * INITIAL_SAFETY_MARGIN / 100 ))
    (( attempt1_kbps < 1 )) && attempt1_kbps=1

    info "Encode attempt 1/2..."
    if encode_video "$attempt1_kbps"; then
        info "Success on first attempt!"
        return 0
    fi

    warn "Over target. Recalculating bitrate for second attempt..."
    local attempt2_kbps=$(( attempt1_kbps * size_bytes_target * CORRECTION_SAFETY_MARGIN / actual_size / 100 ))
    (( attempt2_kbps < 1 )) && attempt2_kbps=1

    info "Encode attempt 2/2..."
    encode_video "$attempt2_kbps"
    info "Final result: $(numfmt --to=iec "$actual_size")."
}


# =============================================================================
# Main
# =============================================================================

main() {
    parse_args "$@"
    resolve_inputs
    probe_source
    calculate_encoding_params
    run_encode_attempts
}

main "$@"
