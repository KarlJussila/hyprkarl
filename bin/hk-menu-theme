#!/bin/bash
# hk-menu-theme
# Menu for selecting a theme

ROFI_THEME="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/custom-menu.rasi"

CHOICE=$(hk-theme list \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Theme" \
           -theme "$ROFI_THEME")

case "$CHOICE" in
    "") exit 1 ;;
    *)  hk-theme set "$CHOICE" ;;
esac

exit 0
