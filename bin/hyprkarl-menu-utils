#!/bin/bash
# hyprkarl-menu-utils
# Menu for common utilities
#
# Usage:
#   hyprkarl-menu-utils [back_cmd]
#
#   back_cmd   Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

back_cmd="$*"

CAFFEINE=" Caffeine"
NIGHTLIGHT=" Nightlight"
SCREEN_RECORD=" Screen Record"

case "$(powerprofilesctl get)" in
    "power-saver")    POWER_PROFILE_ICON="󰌪" ;;
    "balanced")       POWER_PROFILE_ICON="󰗑" ;;
    "performance")    POWER_PROFILE_ICON="󱐋" ;;
    *)                POWER_PROFILE_ICON="󰗑" ;;
esac
POWER_PROFILE="$POWER_PROFILE_ICON Power Profile"

CHOICE=$(echo -e "$CAFFEINE\n$NIGHTLIGHT\n$SCREEN_RECORD\n$POWER_PROFILE" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Utilities" \
           -theme ~/.config/rofi/custom-menu.rasi)

case "$CHOICE" in
    "$CAFFEINE")      hyprkarl-caffeine ;;
    "$NIGHTLIGHT")    hyprkarl-nightlight ;;
    "$SCREEN_RECORD") hyprkarl-record-screen ;;
    "$POWER_PROFILE") hyprkarl-menu-power-profile "hyprkarl-menu-utils $back_cmd" ;;
    "")               [[ -n "$back_cmd" ]] && $back_cmd ;;
esac