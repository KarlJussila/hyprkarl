#!/bin/bash
# hk-fingerprint
# Manage fingerprint authentication and enrolled fingers.
#
# Usage:
#   hk-fingerprint enroll [finger-name]
#   hk-fingerprint list
#   hk-fingerprint remove <finger-name>
#   hk-fingerprint select [message]
#   hk-fingerprint setup [--remove]

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
ACTION_DIR="$SCRIPT_DIR/lib/fingerprint"

usage() {
  cat <<'EOF'
Usage:
  hk-fingerprint enroll [finger-name]
  hk-fingerprint list
  hk-fingerprint remove <finger-name>
  hk-fingerprint select [message]
  hk-fingerprint setup [--remove]
EOF
}

action=${1:-}
shift || true

case "$action" in
  enroll|list|remove|select|setup)
    ;;
  ""|-h|--help|help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac

action_path="$ACTION_DIR/$action.sh"

if [[ ! -x "$action_path" ]]; then
  printf 'Unknown fingerprint subcommand: %s\n' "$action" >&2
  exit 1
fi

exec "$action_path" "$@"
