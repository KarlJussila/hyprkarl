#!/bin/bash
# hk-menu-shell
# Menu for selecting a default shell
#
# Usage:
#   hk-menu-shell [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

ROFI_THEME="${XDG_CONFIG_HOME:-$HOME/.config}/rofi/custom-menu.rasi"

BACK=()
if [[ "${1:-}" == "--back" ]]; then
  shift; BACK=("$@")
fi

FISH=" Fish"
ZSH="󰰶 Zsh"
BASH="󱆃 Bash"

CHOICE=$(echo -e "$FISH\n$ZSH\n$BASH" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Default Shell" \
           -theme "$ROFI_THEME")

case "$CHOICE" in
    "$FISH") hk-open-terminal hk-default-shell fish ;;
    "$ZSH")  hk-open-terminal hk-default-shell zsh ;;
    "$BASH") hk-open-terminal hk-default-shell bash ;;
    "")      (( ${#BACK[@]} )) && "${BACK[@]}" ;;
esac
