#!/bin/bash
# hyprkarl-menu-wallpaper
# Submenu for wallpaper management
#
# Usage:
#   hyprkarl-menu-wallpaper [--back <command> [args...]]
#
#   --back     Optional command to invoke if the user dismisses the menu.
#              Also passed to submenus so they can navigate back to this
#              menu or continue up the call chain. If omitted, dismissing
#              the menu does nothing.

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-shell.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-shell.sh"

hyprkarl_parse_back_args "$@"

SELECT="󰋹 Select"
ADD=" Add"
REMOVE=" Remove"

CHOICE=$(echo -e "$SELECT\n$ADD\n$REMOVE" \
    | rofi -dmenu \
           -p "" \
           -no-custom \
           -mesg "Wallpaper" \
           -theme "$HYPRKARL_ROFI_CUSTOM_THEME")

case "$CHOICE" in
    "$SELECT") hyprkarl-wallpaper-set "$(hyprkarl-wallpaper-select)" ;;
    "$ADD")    hyprkarl-wallpaper-add "$(hyprkarl_capture_terminal_output hyprkarl-select-picture)" ;;
    "$REMOVE") hyprkarl-wallpaper-remove "$(hyprkarl-wallpaper-select '@urgent')" ;;
    "")        hyprkarl_run_back "${HYPRKARL_BACK_ARGS[@]}" ;;
esac
