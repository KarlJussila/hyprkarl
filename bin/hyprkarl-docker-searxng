#!/bin/bash
# hyprkarl-docker-searxng
# Installs or removes the SearXNG Docker stack.
#
# Usage:
#   hyprkarl-docker-searxng [--remove]

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
# shellcheck source=../scripts/lib/hyprkarl-docker.sh
source "$SCRIPT_DIR/../scripts/lib/hyprkarl-docker.sh"

hyprkarl_docker_run_service_command searxng "$@"
