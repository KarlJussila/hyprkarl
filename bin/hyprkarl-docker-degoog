#!/bin/bash
# hyprkarl-docker-degoog
# Installs or removes the degoog Docker container.
#
# Usage:
#   hyprkarl-docker-degoog           Install degoog
#   hyprkarl-docker-degoog --remove  Stop, remove, and delete all degoog data

set -uo pipefail

DEGOOG_DIR="$HOME/.degoog"
DATA_DIR="$DEGOOG_DIR/data"
COMPOSE_FILE="$DEGOOG_DIR/docker-compose.yml"
HOSTS_ENTRY="127.0.0.1 degoog.local"

ensure_network() {
    docker network inspect traefik-proxy &>/dev/null \
        || docker network create traefik-proxy
}

remove() {
    if [[ ! -f "$COMPOSE_FILE" ]]; then
        gum log --level error "No degoog installation found at $DEGOOG_DIR, nothing to do."
        exit 0
    fi

    gum log --level warn "This will stop the degoog container and permanently delete all data in $DEGOOG_DIR."
    if ! gum confirm "Continue?"; then
        gum log --level error "Aborted."
        exit 0
    fi

    gum log --level info "Stopping and removing degoog..."
    docker compose -f "$COMPOSE_FILE" down --rmi all --volumes

    gum log --level info "Deleting $DEGOOG_DIR..."
    sudo rm -rf "$DEGOOG_DIR"

    gum log --level info "Removing /etc/hosts entry..."
    sudo sed -i "/^$HOSTS_ENTRY$/d" /etc/hosts
}

install() {
    gum log --level info "Creating degoog directories..."
    mkdir -p "$DATA_DIR"

    gum log --level info "Ensuring traefik-proxy network exists..."
    ensure_network

    gum log --level info "Fetching docker-compose.yml..."
    curl -fsSL "https://raw.githubusercontent.com/fccview/degoog/main/docker-compose.yml" \
        -o "$COMPOSE_FILE"

    gum log --level info "Adding Traefik labels and network..."
    cat >> "$COMPOSE_FILE" << 'EOF'
    networks:
      - traefik-proxy
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.degoog.rule=Host(`degoog.local`)"
      - "traefik.http.routers.degoog.entrypoints=web"
      - "traefik.http.services.degoog.loadbalancer.server.port=4444"

networks:
  traefik-proxy:
    external: true
EOF

    gum log --level info "Setting ownership..."
    sudo chown 1000:1000 "$DATA_DIR"

    gum log --level info "Adding /etc/hosts entry..."
    if ! grep -qF "$HOSTS_ENTRY" /etc/hosts; then
        echo "$HOSTS_ENTRY" | sudo tee -a /etc/hosts > /dev/null
    fi

    gum log --level info "Starting degoog..."
    docker compose -f "$COMPOSE_FILE" up -d

    gum log --level info "Degoog is available at http://degoog.local (requires Traefik) or http://localhost:4444"
}

case "${1:-}" in
    --remove) remove && hyprkarl-show-done ;;
    "")       install && hyprkarl-show-done ;;
    *)        gum log --level error "Usage: hyprkarl-docker-degoog [--remove]"; exit 1 ;;
esac